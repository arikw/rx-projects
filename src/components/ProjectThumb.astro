---
import type { Project } from '../types/project';
import { sourceLabel } from '../lib/source-label';
import { getBrandMarks } from '../connectors/_registry';

interface Props {
  project: Project;
}
const { project: p } = Astro.props;

// Deterministic hue from slug — same project always gets the same color.
function hashHue(seed: string): number {
  let h = 0;
  for (let i = 0; i < seed.length; i++) {
    h = (h * 31 + seed.charCodeAt(i)) | 0;
  }
  return Math.abs(h) % 360;
}

const hue = hashHue(p.id);
const bgA = `hsl(${hue}, 16%, 19%)`;
const bgB = `hsl(${(hue + 30) % 360}, 14%, 13%)`;
const fg = `hsl(${hue}, 22%, 70%)`;
// If we extracted a dominant colour from the icon at build time, derive the
// backplate from it (mixed with a dark base for legibility). Otherwise fall
// back to the deterministic hash-hue tint.
const iconTint = p.iconColor
  ? `linear-gradient(135deg, color-mix(in srgb, ${p.iconColor} 60%, #15181d 40%), color-mix(in srgb, ${p.iconColor} 32%, #15181d 68%))`
  : `linear-gradient(135deg, ${bgA}, ${bgB})`;
// Thumb-stack (screenshot + icon-overlay) wants a slick PASTEL backplate
// pulled from the icon — high lightness, low saturation, so the icon's
// vignette halo reads soft instead of sitting on a muddy dark plate.
const stackTint = p.iconColor
  ? `linear-gradient(135deg, color-mix(in srgb, ${p.iconColor} 32%, #fdfbf8 68%), color-mix(in srgb, ${p.iconColor} 18%, #fdfbf8 82%))`
  : `linear-gradient(135deg, ${bgA}, ${bgB})`;
const tint = `linear-gradient(135deg, ${bgA}, ${bgB})`;

// Pick layout from what's in each bucket. Connectors decide what kind of
// image they hand the builder (banner / icon / screenshot); the thumb just
// renders the most informative combo available.
const banner = p.banner;
const icon = p.icon;
const screenshot = p.screenshots?.[0];

// Brand-mark fallback for image-less cards (github / npm / docker projects).
// The "what it ships as" identity wins: a github+npm project shows the npm
// wordmark (it's an npm package — github is just where the source happens
// to live), github+docker shows the docker whale, and github-only stays on
// the Octocat. Side benefit: when many projects are github-only-with-no-art,
// adding the npm/docker tints distributes color across the grid so the
// dashboard doesn't read as a wall of identical dark tiles.
// Brand marks are derived from the connector registry (each connector's
// icon.svg + brandMark.tint + brandMark.fg). Sources without a mark fall
// through to the generic gradient placeholder below.
const BRAND_RANK: Record<string, number> = { npm: 0, docker: 1, github: 2 };
const BRAND_MARKS = getBrandMarks();
const brandSourceKey = [...p.sources]
  .filter((s) => s in BRAND_MARKS)
  .sort((a, b) => (BRAND_RANK[a] ?? 99) - (BRAND_RANK[b] ?? 99))[0];
const brand = brandSourceKey ? BRAND_MARKS[brandSourceKey] : null;

const SOURCE_GLYPH: Record<string, string> = {
  github: 'GH',
  npm: 'np',
  docker: 'dh',
  chrome: 'cx',
  gnome: 'gn',
  'google-play': '▸',
  appbrain: '▸',
  apkpure: '▸',
  'chrome-stats': 'cs',
  manual: '·',
};
const primary = p.sources[0] ?? 'manual';
const shortTitle =
  p.title.length <= 18
    ? p.title
    : p.title
        .replace(/[-_]/g, ' ')
        .split(/\s+/)
        .filter(Boolean)
        .map((w) => w[0])
        .slice(0, 3)
        .join('')
        .toUpperCase();
---
<div class="thumb" aria-hidden="true">
  {banner ? (
    p.thumbFit === 'contain' ? (
      <div class="thumb-banner thumb-banner--contain" style={`background: ${p.thumbBg ?? 'transparent'}`}>
        <img src={banner} alt="" loading="lazy" />
      </div>
    ) : (
      <img class="thumb-banner" src={banner} alt="" loading="lazy" />
    )
  ) : screenshot && icon ? (
    <div class="thumb-stack" style={`background: ${stackTint}`}>
      <img class="thumb-bg" src={screenshot} alt="" loading="lazy" />
      <img class="thumb-icon-overlay" src={icon} alt="" loading="lazy" />
    </div>
  ) : icon ? (
    <div class="thumb-iconframe" style={`background: ${iconTint}`}>
      <img class="thumb-icon-centered" src={icon} alt="" loading="lazy" />
    </div>
  ) : screenshot ? (
    p.thumbFit === 'contain' ? (
      <div class="thumb-banner thumb-banner--contain" style={`background: ${p.thumbBg ?? 'transparent'}`}>
        <img src={screenshot} alt="" loading="lazy" />
      </div>
    ) : (
      <img class="thumb-banner" src={screenshot} alt="" loading="lazy" />
    )
  ) : brand ? (
    <div
      class="thumb-brand"
      style={`background: light-dark(${brand.tint}, ${brand.darkTint ?? brand.tint}); color: light-dark(${brand.fg}, ${brand.darkFg ?? brand.fg})`}
    >
      <span class="thumb-brand-mark" set:html={brand.svg} />
    </div>
  ) : (
    <svg class="thumb-svg" viewBox="0 0 320 120" preserveAspectRatio="xMidYMid slice" role="img" aria-hidden="true">
      <defs>
        <linearGradient id={`thumb-grad-${p.id}`} x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color={bgA} />
          <stop offset="1" stop-color={bgB} />
        </linearGradient>
      </defs>
      <rect width="320" height="120" fill={`url(#thumb-grad-${p.id})`} />
      <text
        x="20"
        y="60"
        font-family="ui-sans-serif, system-ui, sans-serif"
        font-size="22"
        font-weight="600"
        fill={fg}
        opacity="0.9"
      >{shortTitle}</text>
      <text
        x="20"
        y="85"
        font-family="ui-monospace, monospace"
        font-size="11"
        fill={fg}
        opacity="0.7"
      >{SOURCE_GLYPH[primary] ?? '·'} · {sourceLabel(primary)}</text>
    </svg>
  )}
</div>
