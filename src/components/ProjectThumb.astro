---
import type { Project } from '../types/project';
import { sourceLabel } from '../lib/source-label';

interface Props {
  project: Project;
}
const { project: p } = Astro.props;

// Deterministic hue from slug — same project always gets the same color.
function hashHue(seed: string): number {
  let h = 0;
  for (let i = 0; i < seed.length; i++) {
    h = (h * 31 + seed.charCodeAt(i)) | 0;
  }
  return Math.abs(h) % 360;
}

const hue = hashHue(p.id);
const bgA = `hsl(${hue}, 16%, 19%)`;
const bgB = `hsl(${(hue + 30) % 360}, 14%, 13%)`;
const fg = `hsl(${hue}, 22%, 70%)`;
const tint = `linear-gradient(135deg, ${bgA}, ${bgB})`;

// Pick layout from what's in each bucket. Connectors decide what kind of
// image they hand the builder (banner / icon / screenshot); the thumb just
// renders the most informative combo available.
const banner = p.banner;
const icon = p.icon;
const screenshot = p.screenshots?.[0];

// Brand-mark fallback for image-less cards (github / npm / docker projects).
// Lowest-rank source wins so a github+npm project shows the github mark.
// Simple Icons paths (CC0). Sources without a mark fall through to the
// generic gradient placeholder below.
const BRAND_RANK: Record<string, number> = { github: 0, npm: 1, docker: 2 };
const BRAND_MARKS: Record<string, { path: string; tint: string; fg: string }> = {
  github: {
    tint: '#0a0c12',
    fg: '#ffffff',
    path: 'M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12',
  },
  npm: {
    tint: '#2d0707',
    fg: '#cb3837',
    path: 'M0 7.334v8h6.666v1.332H12v-1.332h12v-8H0zm6.666 6.664H5.334v-4H3.999v4H1.335V8.667h5.331v5.331zm4 0v1.336H8.001V8.667h5.334v5.332h-2.669v-.001zm12.001 0h-1.33v-4h-1.336v4h-1.335v-4h-1.33v4h-2.671V8.667h8.002v5.331zM10.665 10H12v2.667h-1.335V10z',
  },
  docker: {
    tint: '#061d35',
    fg: '#2496ED',
    path: 'M13.983 11.078h2.119a.186.186 0 00.186-.185V9.006a.186.186 0 00-.186-.186h-2.119a.185.185 0 00-.185.185v1.888c0 .102.083.185.185.185m-2.954-5.43h2.118a.186.186 0 00.186-.186V3.574a.186.186 0 00-.186-.185h-2.118a.185.185 0 00-.185.185v1.888c0 .102.082.185.185.186m0 2.716h2.118a.187.187 0 00.186-.186V6.29a.186.186 0 00-.186-.185h-2.118a.185.185 0 00-.185.185v1.887c0 .102.082.185.185.186m-2.93 0h2.12a.186.186 0 00.184-.186V6.29a.185.185 0 00-.185-.185H8.1a.185.185 0 00-.185.185v1.887c0 .102.083.185.185.186m-2.964 0h2.119a.186.186 0 00.185-.186V6.29a.185.185 0 00-.185-.185H5.136a.186.186 0 00-.186.185v1.887c0 .102.084.185.186.186m5.893 2.715h2.118a.186.186 0 00.186-.185V9.006a.186.186 0 00-.186-.186h-2.118a.185.185 0 00-.185.185v1.888c0 .102.082.185.185.185m-2.93 0h2.12a.185.185 0 00.184-.185V9.006a.185.185 0 00-.184-.186h-2.12a.185.185 0 00-.185.185v1.888c0 .102.083.185.185.185m-2.964 0h2.119a.185.185 0 00.185-.185V9.006a.185.185 0 00-.184-.186h-2.12a.186.186 0 00-.186.186v1.887c0 .102.084.185.186.185m-2.92 0h2.12a.185.185 0 00.184-.185V9.006a.185.185 0 00-.184-.186h-2.12a.185.185 0 00-.184.185v1.888c0 .102.082.185.185.185M23.763 9.89c-.065-.051-.672-.51-1.954-.51-.338.001-.676.03-1.01.087-.248-1.7-1.653-2.53-1.716-2.566l-.344-.199-.226.327c-.284.438-.49.922-.612 1.43-.23.97-.09 1.882.403 2.661-.595.332-1.55.413-1.744.42H.751a.751.751 0 00-.75.748 11.376 11.376 0 00.692 4.062c.545 1.428 1.355 2.48 2.41 3.124 1.18.723 3.1 1.137 5.275 1.137.983.003 1.963-.086 2.93-.266a12.248 12.248 0 003.823-1.389c.98-.567 1.86-1.288 2.61-2.136 1.252-1.418 1.998-2.997 2.553-4.4h.221c1.372 0 2.215-.549 2.68-1.009.309-.293.55-.65.707-1.046l.098-.288Z',
  },
};
const brandSourceKey = [...p.sources]
  .filter((s): s is keyof typeof BRAND_MARKS => s in BRAND_MARKS)
  .sort((a, b) => BRAND_RANK[a] - BRAND_RANK[b])[0];
const brand = brandSourceKey ? BRAND_MARKS[brandSourceKey] : null;

const SOURCE_GLYPH: Record<string, string> = {
  github: 'GH',
  npm: 'np',
  docker: 'dh',
  chrome: 'cx',
  gnome: 'gn',
  'google-play': '▸',
  appbrain: '▸',
  apkpure: '▸',
  'chrome-stats': 'cs',
  manual: '·',
};
const primary = p.sources[0] ?? 'manual';
const shortTitle =
  p.title.length <= 18
    ? p.title
    : p.title
        .replace(/[-_]/g, ' ')
        .split(/\s+/)
        .filter(Boolean)
        .map((w) => w[0])
        .slice(0, 3)
        .join('')
        .toUpperCase();
---
<div class="thumb" aria-hidden="true">
  {banner ? (
    <img class="thumb-banner" src={banner} alt="" loading="lazy" />
  ) : screenshot && icon ? (
    <div class="thumb-stack" style={`background: ${tint}`}>
      <img class="thumb-bg" src={screenshot} alt="" loading="lazy" />
      <img class="thumb-icon-overlay" src={icon} alt="" loading="lazy" />
    </div>
  ) : icon ? (
    <div class="thumb-iconframe" style={`background: ${tint}`}>
      <img class="thumb-icon-centered" src={icon} alt="" loading="lazy" />
    </div>
  ) : screenshot ? (
    <img class="thumb-banner" src={screenshot} alt="" loading="lazy" />
  ) : brand ? (
    <div class="thumb-brand" style={`background: ${brand.tint}`}>
      <svg class="thumb-brand-mark" viewBox="0 0 24 24" fill={brand.fg}>
        <path d={brand.path} />
      </svg>
    </div>
  ) : (
    <svg class="thumb-svg" viewBox="0 0 320 84" preserveAspectRatio="xMidYMid slice" role="img" aria-hidden="true">
      <defs>
        <linearGradient id={`thumb-grad-${p.id}`} x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color={bgA} />
          <stop offset="1" stop-color={bgB} />
        </linearGradient>
      </defs>
      <rect width="320" height="84" fill={`url(#thumb-grad-${p.id})`} />
      <text
        x="20"
        y="42"
        font-family="ui-sans-serif, system-ui, sans-serif"
        font-size="22"
        font-weight="600"
        fill={fg}
        opacity="0.9"
      >{shortTitle}</text>
      <text
        x="20"
        y="66"
        font-family="ui-monospace, monospace"
        font-size="11"
        fill={fg}
        opacity="0.7"
      >{SOURCE_GLYPH[primary] ?? '·'} · {sourceLabel(primary)}</text>
    </svg>
  )}
</div>
