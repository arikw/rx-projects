---
interface Props {
  value: string;
  label: string;
  sublabel?: string;
  /** Same keys as ProjectCard's stat-icon — keeps the hero stats and the
   *  card stats visually aligned so the hero acts as a legend. */
  icon?: 'star' | 'download' | 'users' | 'projects';
  /** Free-form explanation surfaced via a tooltip when the user hovers /
   *  focuses the small (?) button next to the label. Use this for details
   *  too long for the sublabel (e.g. the list of source platforms that
   *  contributed to the metric). */
  info?: string;
}
const { value, label, sublabel, icon, info } = Astro.props;
---
<div class="stat" data-stat-key={icon ?? ''}>
  <span class="stat-delta" hidden></span>
  <div class="stat-value">{value}</div>
  <div class="stat-label">
    {icon === 'star' && (
      <svg class="stat-label-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="currentColor" d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
      </svg>
    )}
    {icon === 'download' && (
      <svg class="stat-label-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="currentColor" d="M5 20h14v-2H5v2zM19 9h-4V3H9v6H5l7 7 7-7z" />
      </svg>
    )}
    {icon === 'users' && (
      <svg class="stat-label-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="currentColor" d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
      </svg>
    )}
    {icon === 'projects' && (
      <svg class="stat-label-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="currentColor" d="M3 5h7l2 2h9v12H3V5zm2 2v10h14V9h-7.83l-2-2H5z" />
      </svg>
    )}
    <span>{label}</span>
    {info && (
      <span class="stat-info">
        <button
          type="button"
          class="stat-info-button"
          aria-label={`More about ${label}`}
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.75" />
            <path
              d="M9.5 9.5a2.5 2.5 0 1 1 3.5 2.3c-.7.3-1 .9-1 1.7"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <circle cx="12" cy="17" r="1" fill="currentColor" />
          </svg>
        </button>
        <span class="stat-info-tooltip" role="tooltip">{info}</span>
      </span>
    )}
  </div>
  {sublabel && <div class="stat-sublabel">{sublabel}</div>}
</div>

<script>
  // (?) tooltip: position near the trigger, clamp to viewport edges,
  // flip vertically when there's no room below. Show/hide is driven by
  // a `.show` class on the tooltip so scroll-dismiss and tap-outside
  // can directly toggle visibility regardless of focus state (mobile
  // browsers don't always focus buttons on tap, so a CSS :focus-within
  // approach would fail to dismiss reliably).
  function positionTooltip(group: Element) {
    const button = group.querySelector<HTMLButtonElement>('.stat-info-button');
    const tip = group.querySelector<HTMLElement>('.stat-info-tooltip');
    if (!button || !tip) return;

    const trigger = button.getBoundingClientRect();
    const tipW = tip.offsetWidth;
    const tipH = tip.offsetHeight;
    const pad = 8;
    const vw = document.documentElement.clientWidth;
    const vh = window.innerHeight;
    // `scrollbar-gutter: stable both-edges` on <html> shifts the
    // fixed-positioning containing block horizontally by the gutter
    // width (~22px on desktop). Compensate by subtracting html's
    // left from the inline `left` we set. The vertical axis is NOT
    // affected — `position: fixed` is viewport-relative for `top`
    // regardless of scroll position, so subtracting htmlRect.top
    // would over-correct as the page scrolls (htmlRect.top goes
    // negative as you scroll down).
    const htmlLeft = document.documentElement.getBoundingClientRect().left;

    const triggerCenterX = trigger.left + trigger.width / 2;

    // Horizontal: centre on trigger, clamp to viewport edges (using
    // viewport coords — clamp boundary doesn't care about html offset).
    let leftV = triggerCenterX - tipW / 2;
    leftV = Math.max(pad, Math.min(leftV, vw - tipW - pad));

    // Vertical: below trigger by default; flip above if it would
    // extend past the viewport bottom. The .flip-up class moves the
    // arrow to the bottom edge so it still points at the trigger.
    let topV = trigger.bottom + 8;
    const flipUp = topV + tipH > vh - pad;
    if (flipUp) topV = trigger.top - tipH - 8;
    tip.classList.toggle('flip-up', flipUp);

    tip.style.left = `${leftV - htmlLeft}px`;
    tip.style.top = `${topV}px`;
    // Arrow offset within the tooltip — tooltip-local coords, so the
    // html offset doesn't enter the calculation.
    tip.style.setProperty('--arrow-left', `${triggerCenterX - leftV}px`);
  }

  function hideAll() {
    document.querySelectorAll('.stat-info-tooltip.show').forEach((t) => t.classList.remove('show'));
  }

  function showFor(group: Element) {
    // Hide any other tooltip first, then position + show this one.
    hideAll();
    const tip = group.querySelector<HTMLElement>('.stat-info-tooltip');
    if (!tip) return;
    positionTooltip(group);
    tip.classList.add('show');
  }

  function init() {
    const groups = document.querySelectorAll('.stat-info');
    groups.forEach((group) => {
      const button = group.querySelector<HTMLButtonElement>('.stat-info-button');
      if (!button) return;
      button.addEventListener('mouseenter', () => showFor(group));
      button.addEventListener('mouseleave', hideAll);
      button.addEventListener('focus', () => showFor(group));
      button.addEventListener('blur', hideAll);
      // Touch: explicit handler so we don't depend on focus being set
      // by the browser on tap. stopPropagation keeps the document-level
      // touchstart (below) from immediately re-hiding.
      button.addEventListener('touchstart', (e) => {
        e.stopPropagation();
        showFor(group);
      }, { passive: true });
    });

    // Dismiss on scroll — both kinds, covering desktop wheel/keyboard
    // scroll and mobile touch-driven scroll.
    window.addEventListener('scroll', hideAll, { passive: true });
    window.addEventListener('touchmove', hideAll, { passive: true });
    // Dismiss on tap-outside (mobile pattern).
    document.addEventListener('touchstart', (e) => {
      if (!(e.target instanceof Element) || !e.target.closest('.stat-info')) hideAll();
    }, { passive: true });
    // Reposition on viewport change while a tooltip is showing.
    window.addEventListener('resize', () => {
      const shown = document.querySelector('.stat-info-tooltip.show');
      if (shown && shown.parentElement) positionTooltip(shown.parentElement);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
