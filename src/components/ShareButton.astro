---
// Share button — invokes the Web Share API on platforms that support
// it (every mobile browser plus recent macOS / Windows builds),
// falling back to a clipboard copy with brief checkmark feedback on
// desktop browsers that don't have a share sheet.
//
// Lives alongside the theme toggle in the header so users see one
// "share / theme" pair instead of having to hunt for either action.
---
<button
  type="button"
  class="share-button"
  aria-label="Share this page"
  title="Share this page"
  data-share-button
>
  <svg class="share-icon share-icon-share" viewBox="0 0 24 24" aria-hidden="true">
    <g
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="18" cy="5" r="2.75" />
      <circle cx="6" cy="12" r="2.75" />
      <circle cx="18" cy="19" r="2.75" />
      <line x1="8.4" y1="13.4" x2="15.6" y2="17.6" />
      <line x1="15.6" y1="6.4" x2="8.4" y2="10.6" />
    </g>
  </svg>
  <svg class="share-icon share-icon-check" viewBox="0 0 24 24" aria-hidden="true">
    <path
      d="M5 12.5L10 17.5L20 7.5"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
</button>

<script>
  /** Copy text via the legacy `document.execCommand('copy')` route.
   *  Modern clipboard / Web Share APIs require a secure context — on
   *  `http://` LAN dev (e.g. testing on a phone against your laptop's
   *  IP) they're unavailable / throw. execCommand is deprecated but
   *  still works in every browser and crucially works in insecure
   *  contexts, so it's our floor for "the button does something". */
  function copyViaExecCommand(text: string): boolean {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.setAttribute('readonly', '');
    ta.style.position = 'fixed';
    ta.style.opacity = '0';
    ta.style.left = '-9999px';
    document.body.appendChild(ta);
    ta.select();
    let ok = false;
    try { ok = document.execCommand('copy'); } catch { ok = false; }
    document.body.removeChild(ta);
    return ok;
  }

  function flashCopied(btn: HTMLButtonElement): void {
    btn.classList.add('share-copied');
    btn.setAttribute('aria-label', 'Link copied to clipboard');
    setTimeout(() => {
      btn.classList.remove('share-copied');
      btn.setAttribute('aria-label', 'Share this page');
    }, 1500);
  }

  document.querySelectorAll<HTMLButtonElement>('[data-share-button]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = location.href;
      const shareData: ShareData = { title: document.title, url };
      // og:description is already on every page (BaseHead always emits
      // it). Surface it as the share sheet's text body so WhatsApp /
      // Mail / etc. prefill a meaningful description.
      const desc = document
        .querySelector<HTMLMetaElement>('meta[name="description"]')?.content;
      if (desc) shareData.text = desc;

      // Path 1 — Web Share API. Mobile + recent macOS / Windows. Only
      // works in a SECURE context (https or localhost). On http:// LAN
      // the function isn't even defined, so we drop straight through.
      if (typeof navigator.share === 'function') {
        try {
          await navigator.share(shareData);
          return;
        } catch (err) {
          // User dismissed the share sheet — they're done, no fallback.
          if ((err as DOMException)?.name === 'AbortError') return;
          // Any other error: fall through to clipboard.
        }
      }

      // Path 2 — async Clipboard API. Also secure-context only, so it
      // throws on http:// LAN. Wrapped in try/catch so we silently
      // fall through to execCommand without surfacing the error.
      if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
        try {
          await navigator.clipboard.writeText(url);
          flashCopied(btn);
          return;
        } catch {
          // Fall through to execCommand.
        }
      }

      // Path 3 — execCommand. The insecure-context floor.
      if (copyViaExecCommand(url)) flashCopied(btn);
      // Everything failed: the click really does nothing. We accept
      // this for the very rare browser that strips both APIs and
      // also blocks execCommand.
    });
  });
</script>
