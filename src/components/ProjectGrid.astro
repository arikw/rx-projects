---
import ProjectCard from './ProjectCard.astro';
import FilterBar from './FilterBar.astro';
import type { Project } from '../types/project';
import config from '../lib/load-config';
import { getPlatformToSourceGroup, getOrigins, getSourceGroup } from '../connectors/_registry';
import { contentLanguageLabel } from '../lib/content-language';

interface Props {
  projects: Project[];
  pageSize: number;
}
const { projects, pageSize } = Astro.props;

// Map a project's raw sources (origin/native platforms) to a friendlier
// "filter group" key for the source-filter chips. google-play / apkpure /
// appbrain all belong to the android group; registered connectors pass
// through their own key; everything else (e.g. a one-off `'firefox'` set
// by a ManualProject's `source` field) falls back to its platform key
// directly so it still gets a chip.
const SOURCE_TO_GROUP: Record<string, string> = getPlatformToSourceGroup();
// Chip display order: each registered origin's source-group, deduped, in
// manifest order. Unregistered groups (one-offs from ManualProject.source)
// are appended alphabetically after the registered ones.
const REGISTERED_ORDER = [...new Set(getOrigins().map((m) => getSourceGroup(m.key)))];

function projectGroups(p: Project): string[] {
  const set = new Set<string>();
  for (const s of p.sources) set.add(SOURCE_TO_GROUP[s] ?? s);
  return [...set];
}

const groupCounts = new Map<string, number>();
for (const p of projects) {
  for (const g of projectGroups(p)) {
    groupCounts.set(g, (groupCounts.get(g) ?? 0) + 1);
  }
}
const extraGroups = [...groupCounts.keys()]
  .filter((g) => !REGISTERED_ORDER.includes(g))
  .sort();
const sourceChips = [...REGISTERED_ORDER, ...extraGroups]
  .filter((g) => groupCounts.has(g))
  .map((g) => ({ key: g, label: g, count: groupCounts.get(g)! }));

// Tag filter — top-N tags by count, with overflow revealed via a toggle.
// Counts are global to start; the client-side script updates them per source
// filter as the user picks one.
const tagsCfg = config.tags ?? {};
const topN = tagsCfg.topN ?? 8;
const minCount = tagsCfg.minCount ?? 2;
const excludeSet = new Set((tagsCfg.exclude ?? []).map((s) => s.toLowerCase()));
const tagCounts = new Map<string, number>();
for (const p of projects) {
  for (const t of p.tags ?? []) {
    if (excludeSet.has(t.toLowerCase())) continue;
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const sortedTags = Array.from(tagCounts.entries())
  .filter(([, count]) => count >= minCount)
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name));
const primaryTags = sortedTags.slice(0, topN);
const overflowTags = sortedTags.slice(topN);

// Content-language filter — counts per detected language code. Undefined
// content-language is treated as English ('en'). The row only renders
// when at least one non-default language is present; otherwise every
// project is English and the filter would be pointless. Chip order:
// English first, then others by count desc, then code alphabetic.
const languageCounts = new Map<string, number>();
for (const p of projects) {
  const code = p.contentLanguage || 'en';
  languageCounts.set(code, (languageCounts.get(code) ?? 0) + 1);
}
const hasNonDefaultLanguage = [...languageCounts.keys()].some((c) => c !== 'en');
const languageChips = hasNonDefaultLanguage
  ? [
      ...(languageCounts.has('en')
        ? [{ key: 'en', label: contentLanguageLabel('en'), count: languageCounts.get('en')! }]
        : []),
      ...[...languageCounts.entries()]
        .filter(([k]) => k !== 'en')
        .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
        .map(([k, count]) => ({ key: k, label: contentLanguageLabel(k), count })),
    ]
  : [];
const defaultLanguage = config.meta.defaultLanguage ?? '';

// Status filter — only renders when at least one retired project exists.
const liveCount = projects.filter((p) => !p.retired).length;
const retiredCount = projects.length - liveCount;
const statusChips: { key: 'live' | 'retired'; label: string; count: number }[] =
  retiredCount > 0
    ? [
        { key: 'live', label: 'Live', count: liveCount },
        { key: 'retired', label: 'Retired', count: retiredCount },
      ]
    : [];
---
<section
  class="projects"
  data-page-size={pageSize}
  data-default-language={defaultLanguage}
>
  <header class="section-head">
    <span class="section-label">Projects gallery</span>
    <span class="section-rule" aria-hidden="true"></span>
    <button
      type="button"
      class="section-reset"
      data-filter-reset
      hidden
    >
      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
      <span>Reset filters</span>
    </button>
    <span class="section-count">{String(projects.length).padStart(2, '0')}</span>
  </header>

  <FilterBar
    totalCount={projects.length}
    sources={sourceChips}
    primaryTags={primaryTags}
    overflowTags={overflowTags}
    languages={languageChips}
    statuses={statusChips}
  />

  <div class="projects-grid">
    {projects.map((p) => {
      const rank = config.featured.indexOf(p.id);
      return (
        <ProjectCard
          project={p}
          sourceGroups={projectGroups(p).join(' ')}
          tagList={(p.tags ?? []).join(' ')}
          contentLanguage={p.contentLanguage || 'en'}
          featuredRank={rank >= 0 ? rank : undefined}
        />
      );
    })}
  </div>

  <p class="projects-empty" hidden>
    No projects match the current filters.
    <button type="button" class="projects-empty-reset" data-filter-reset>Reset filters</button>
  </p>

  <div class="projects-more">
    <button type="button" class="show-more">Show more</button>
  </div>
  <div class="gallery-reset" hidden>
    <button type="button" class="reset-link" data-filter-reset>
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
      <span>Reset filters</span>
    </button>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const root = document.querySelector<HTMLElement>('.projects');
    if (!root) return;
    const pageSize = parseInt(root.dataset.pageSize ?? '12', 10);
    const grid = root.querySelector<HTMLElement>('.projects-grid');
    const empty = root.querySelector<HTMLElement>('.projects-empty');
    const moreBtn = root.querySelector<HTMLButtonElement>('.show-more');
    if (!grid || !empty || !moreBtn) return;

    const sourceChips = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-filter-source]'));
    const sortChips = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-filter-sort]'));
    const tagChips = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-filter-tag]'));
    const languageChips = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-filter-language]'));
    let statusChips = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-filter-status]'));
    const tagToggle = root.querySelector<HTMLButtonElement>('[data-tag-toggle]');
    const totalCountEl = root.querySelector<HTMLElement>('[data-tag-count-total]');
    const resetButtons = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-filter-reset]'));
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.card'));
    // Language defaults come in two layers — see the comments below for
    // why each exists. Hash param `lang=` overrides both; "" means "All".
    //   `configDefaultLanguage` — what the dashboard config says.
    //   `environmentDefaultLanguage` — auto-relax to "All" when the
    //       browser advertises a non-default project content-language
    //       (e.g. Hebrew browser sees Hebrew apps by default). Used for
    //       the writeHash() comparison: the hash only appears when the
    //       active filter differs from the visiting browser's natural
    //       default, so shared URLs without a hash render the same way
    //       across visitors with the same environment.
    //   `personalDefaultLanguage` — the user's saved preference, if any
    //       (localStorage). Wins for the initial-load filter so a
    //       returning visitor sees what they last chose. Deliberately
    //       NOT used by writeHash(): including it would let a saved
    //       preference suppress hash params and break URL sharing
    //       (the recipient's localStorage isn't ours).
    const configDefaultLanguage = root.dataset.defaultLanguage ?? '';
    const LANG_STORAGE_KEY = 'rxp:lang-filter';
    const projectLanguages = new Set(
      Array.from(root.querySelectorAll<HTMLButtonElement>('[data-filter-language]'))
        .map((c) => c.dataset.filterLanguage ?? '')
        .filter(Boolean),
    );
    function detectEnvironmentDefault(): string {
      // Look for any preferred browser language whose base code matches a
      // project content-language and ISN'T the config default. If found,
      // relax the default to "" (All). Otherwise stick with the config.
      const prefs = Array.isArray(navigator.languages) ? navigator.languages : [navigator.language];
      for (const pref of prefs) {
        const base = (pref || '').split('-')[0].toLowerCase();
        if (!base || base === configDefaultLanguage) continue;
        if (projectLanguages.has(base)) return '';
      }
      return configDefaultLanguage;
    }
    const environmentDefaultLanguage = detectEnvironmentDefault();
    const storedLang = (() => {
      try { return localStorage.getItem(LANG_STORAGE_KEY); } catch { return null; }
    })();
    const personalDefaultLanguage = storedLang !== null ? storedLang : environmentDefaultLanguage;

    type Sort = 'featured' | 'popularity' | 'year';
    type Status = '' | 'live' | 'retired' | 'updated';
    let activeSource = '';
    let activeSort: Sort = 'featured';
    let activeTag = '';
    let activeLanguage = personalDefaultLanguage;
    let activeStatus: Status = '';
    let shown = pageSize;
    let overflowExpanded = false;

    const popularityOf = (c: HTMLElement) => parseFloat(c.dataset.popularity ?? '0');
    const featuredScoreOf = (c: HTMLElement) => parseFloat(c.dataset.featuredScore ?? '0');
    const yearOf = (c: HTMLElement) => parseInt(c.dataset.year ?? '0', 10);
    // Featured rank: 0-based index in config.featured for pinned projects,
    // Infinity for everything else. Drives the default "Featured" sort.
    const featuredRankOf = (c: HTMLElement) => {
      const r = parseInt(c.dataset.featuredRank ?? '', 10);
      return Number.isFinite(r) ? r : Infinity;
    };
    const tagsOf = (c: HTMLElement) =>
      (c.dataset.tags ?? '').split(' ').filter(Boolean);
    const matchesSource = (c: HTMLElement) =>
      !activeSource ||
      (c.dataset.sourceGroups ?? '').split(' ').filter(Boolean).includes(activeSource);
    const matchesTag = (c: HTMLElement) =>
      !activeTag || tagsOf(c).includes(activeTag);
    const matchesLanguage = (c: HTMLElement) =>
      !activeLanguage ||
      (c.dataset.contentLanguage || 'en') === activeLanguage;
    const matchesStatus = (c: HTMLElement) => {
      if (!activeStatus) return true;
      if (activeStatus === 'updated') return c.dataset.updated === '1';
      return (c.dataset.status ?? 'live') === activeStatus;
    };

    /** Recompute the tag chip counts to reflect the active source filter. Tags
     *  that don't appear under the current source get hidden; the "+N more"
     *  toggle's label updates with the remaining overflow count.
     *  When primary tags hide because the source filter zeroed their counts,
     *  overflow tags WITH non-zero counts are promoted into the freed slots
     *  so the tag row stays dense — otherwise the user sees "All" + "+N more"
     *  with empty space where the primary chips used to be. */
    const primarySlotCount = tagChips.filter(
      (c) => c.dataset.filterTag && !c.classList.contains('filter-chip--overflow'),
    ).length;

    function refreshTagCounts() {
      const sourceMatching = cards.filter(matchesSource);
      const counts = new Map<string, number>();
      for (const c of sourceMatching) {
        for (const t of tagsOf(c)) counts.set(t, (counts.get(t) ?? 0) + 1);
      }
      if (totalCountEl) totalCountEl.textContent = String(sourceMatching.length);

      // Pass 1: write the live counts, partition the chips with non-zero
      // counts into "primary" (initially-primary, naturally visible) and
      // "available overflow" (currently overflow but eligible to promote).
      const visiblePrimaries: HTMLButtonElement[] = [];
      const availableOverflow: HTMLButtonElement[] = [];
      tagChips.forEach((chip) => {
        const tag = chip.dataset.filterTag ?? '';
        if (!tag) return; // "All" chip handled via totalCountEl
        const count = counts.get(tag) ?? 0;
        const valueEl = chip.querySelector<HTMLElement>('.filter-count');
        if (valueEl) valueEl.textContent = String(count);
        if (count === 0) {
          chip.setAttribute('hidden', '');
          return;
        }
        if (chip.classList.contains('filter-chip--overflow')) {
          availableOverflow.push(chip);
        } else {
          visiblePrimaries.push(chip);
        }
      });

      // Pass 2: show every visible primary; fill any freed primary slots
      // with available overflow chips; the rest of the overflow waits
      // behind the "+N more" toggle (or shows now if user expanded it).
      visiblePrimaries.forEach((c) => c.removeAttribute('hidden'));
      const freeSlots = Math.max(0, primarySlotCount - visiblePrimaries.length);
      const promoted = availableOverflow.slice(0, freeSlots);
      const stillHidden = availableOverflow.slice(freeSlots);
      promoted.forEach((c) => c.removeAttribute('hidden'));
      stillHidden.forEach((c) => {
        if (overflowExpanded) c.removeAttribute('hidden');
        else c.setAttribute('hidden', '');
      });

      if (tagToggle) {
        if (stillHidden.length === 0) {
          tagToggle.setAttribute('hidden', '');
        } else {
          tagToggle.removeAttribute('hidden');
          if (!overflowExpanded) {
            tagToggle.textContent = `+ ${stillHidden.length} more`;
          }
        }
      }
    }

    function applyFilter() {
      const matching = cards.filter(
        (c) => matchesSource(c) && matchesTag(c) && matchesLanguage(c) && matchesStatus(c),
      );

      const sorted = matching.slice().sort((a, b) => {
        if (activeSort === 'year') return yearOf(b) - yearOf(a);
        if (activeSort === 'featured') {
          // Mirror the SSR sort in index.astro: pinned items first,
          // then exact featuredScore desc, title alpha as deterministic
          // tiebreak.
          const ra = featuredRankOf(a);
          const rb = featuredRankOf(b);
          if (ra !== rb) return ra - rb;
          const sa = featuredScoreOf(a);
          const sb = featuredScoreOf(b);
          if (sa !== sb) return sb - sa;
          const ta = a.querySelector('.card-title h3')?.textContent ?? '';
          const tb = b.querySelector('.card-title h3')?.textContent ?? '';
          return ta.localeCompare(tb);
        }
        return popularityOf(b) - popularityOf(a);
      });

      cards.forEach((c) => c.classList.add('is-hidden'));
      sorted.slice(0, shown).forEach((c) => {
        c.classList.remove('is-hidden');
        grid.appendChild(c);
      });
      const visibleSet = new Set(sorted.slice(0, shown));
      cards.filter((c) => !visibleSet.has(c)).forEach((c) => grid.appendChild(c));

      empty.hidden = matching.length > 0;
      // Toggle the more/less button:
      //   - more cards available than currently shown  → "Show more ⌄"
      //   - all shown AND more than pageSize total     → "Show less ⌃"
      //   - everything else (small set, nothing left to do) → hidden.
      const canExpand = matching.length > shown;
      const isExpanded = !canExpand && matching.length > pageSize;
      const chevron = (dir: 'down' | 'up') => {
        const points = dir === 'down' ? '6 9 12 15 18 9' : '18 15 12 9 6 15';
        return `<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="${points}"/></svg>`;
      };
      if (canExpand) {
        moreBtn.innerHTML = `<span>Show more</span>${chevron('down')}`;
        moreBtn.dataset.mode = 'more';
        moreBtn.removeAttribute('hidden');
      } else if (isExpanded) {
        moreBtn.innerHTML = `<span>Show less</span>${chevron('up')}`;
        moreBtn.dataset.mode = 'less';
        moreBtn.removeAttribute('hidden');
      } else {
        moreBtn.setAttribute('hidden', '');
      }
      updateResetVisibility();
    }

    /** Filters are at defaults when source / tag are unset and sort is
     *  the implicit default ('featured'). show-all / tags-expanded are
     *  not considered filters — they're view preferences, kept across
     *  reset so the user doesn't lose their place. */
    function isDefaultState() {
      return (
        !activeSource &&
        activeSort === 'featured' &&
        !activeTag &&
        activeLanguage === personalDefaultLanguage &&
        !activeStatus
      );
    }

    const galleryResetWrap = root.querySelector<HTMLElement>('.gallery-reset');
    function updateResetVisibility() {
      const hide = isDefaultState();
      resetButtons.forEach((b) => {
        if (hide) b.setAttribute('hidden', '');
        else b.removeAttribute('hidden');
      });
      // .gallery-reset is the wrapper around the bottom button; hide
      // it as a block (display: none via [hidden]) so it doesn't
      // leave a phantom centred row at the end of the gallery when
      // filters are at defaults. The section-head version uses
      // visibility:hidden via its own CSS so the count doesn't shift.
      if (galleryResetWrap) {
        if (hide) galleryResetWrap.setAttribute('hidden', '');
        else galleryResetWrap.removeAttribute('hidden');
      }
    }

    function resetFilters() {
      activeSource = '';
      activeSort = 'featured';
      activeTag = '';
      activeLanguage = personalDefaultLanguage;
      activeStatus = '';
      shown = pageSize;
      sourceChips.forEach((c) => {
        c.setAttribute('aria-pressed', String(!c.dataset.filterSource));
      });
      sortChips.forEach((c) => {
        c.setAttribute('aria-pressed', String(c.dataset.filterSort === 'featured'));
      });
      tagChips.forEach((c) => {
        c.setAttribute('aria-pressed', String(!c.dataset.filterTag));
      });
      languageChips.forEach((c) => {
        c.setAttribute('aria-pressed', String((c.dataset.filterLanguage ?? '') === activeLanguage));
      });
      statusChips.forEach((c) => {
        c.setAttribute('aria-pressed', String((c.dataset.filterStatus ?? '') === activeStatus));
      });
      refreshTagCounts();
      writeHash();
      applyFilter();
      // After reset, the user is no longer in the same context (their
      // active filter is gone, cards re-ordered to defaults). Scroll
      // back to the top of the section so they see the first card of
      // the now-unfiltered view instead of mid-page in a different
      // ordering.
      root.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    resetButtons.forEach((b) => b.addEventListener('click', resetFilters));

    function setSource(source: string) {
      activeSource = source;
      shown = pageSize;
      sourceChips.forEach((c) => {
        c.setAttribute('aria-pressed', String((c.dataset.filterSource ?? '') === source));
      });
      // If the previously active tag no longer exists under this source, clear it.
      refreshTagCounts();
      if (activeTag) {
        const chip = tagChips.find((c) => c.dataset.filterTag === activeTag);
        if (chip?.hasAttribute('hidden')) {
          setTag('');
          return;
        }
      }
      writeHash();
      applyFilter();
    }

    function setSort(sort: Sort) {
      activeSort = sort;
      shown = pageSize;
      sortChips.forEach((c) => {
        c.setAttribute('aria-pressed', String(c.dataset.filterSort === sort));
      });
      writeHash();
      applyFilter();
    }

    function setTag(tag: string) {
      activeTag = tag;
      shown = pageSize;
      tagChips.forEach((c) => {
        c.setAttribute('aria-pressed', String((c.dataset.filterTag ?? '') === tag));
      });
      writeHash();
      applyFilter();
    }

    function setLanguage(lang: string, persist = true) {
      activeLanguage = lang;
      shown = pageSize;
      languageChips.forEach((c) => {
        c.setAttribute('aria-pressed', String((c.dataset.filterLanguage ?? '') === lang));
      });
      if (persist) {
        // Save explicit chip clicks so the next visit (without a hash)
        // restores the choice. Programmatic resets pass persist=false to
        // avoid burning the user's preference on a Reset Filters click.
        try { localStorage.setItem(LANG_STORAGE_KEY, lang); } catch { /* private mode etc. */ }
      }
      writeHash();
      applyFilter();
    }

    function setStatus(status: Status) {
      activeStatus = status;
      shown = pageSize;
      statusChips.forEach((c) => {
        c.setAttribute('aria-pressed', String((c.dataset.filterStatus ?? '') === status));
      });
      writeHash();
      applyFilter();
    }

    // Click handlers toggle: pressing an already-active chip resets
    // that axis to its default (the implicit "All" / "Featured"
    // value) so the user doesn't have to hunt for the default chip
    // to deselect.
    sourceChips.forEach((c) => {
      c.addEventListener('click', () => {
        const val = c.dataset.filterSource ?? '';
        setSource(val === activeSource ? '' : val);
      });
    });
    sortChips.forEach((c) => {
      c.addEventListener('click', () => {
        const val = (c.dataset.filterSort as Sort) ?? 'featured';
        setSort(val === activeSort ? 'featured' : val);
      });
    });
    tagChips.forEach((c) => {
      c.addEventListener('click', () => {
        const val = c.dataset.filterTag ?? '';
        setTag(val === activeTag ? '' : val);
      });
    });
    languageChips.forEach((c) => {
      c.addEventListener('click', () => {
        const val = c.dataset.filterLanguage ?? '';
        // Toggle: click an already-active chip → revert to the personal
        // default (saved preference, browser-detected, then config).
        // Click a different chip → switch to it. Either way, persist
        // the resulting selection.
        setLanguage(val === activeLanguage ? personalDefaultLanguage : val);
      });
    });
    statusChips.forEach((c) => {
      c.addEventListener('click', () => {
        const val = (c.dataset.filterStatus ?? '') as Status;
        setStatus(val === activeStatus ? '' : val);
      });
    });

    if (tagToggle) {
      const overflowCount = parseInt(tagToggle.dataset.overflowCount ?? '0', 10);
      tagToggle.addEventListener('click', () => {
        overflowExpanded = !overflowExpanded;
        tagToggle.setAttribute('aria-expanded', String(overflowExpanded));
        tagToggle.textContent = overflowExpanded
          ? 'Fewer tags'
          : `+ ${overflowCount} more`;
        refreshTagCounts();
        writeHash();
      });
    }

    moreBtn.addEventListener('click', () => {
      if (moreBtn.dataset.mode === 'less') {
        shown = pageSize;
        writeHash();
        applyFilter();
        // Collapse jumps the user back to a position where the cards
        // that were visible may no longer be — scroll to section top
        // so they land on the first page of the collapsed view.
        root.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        shown = cards.length;
        writeHash();
        applyFilter();
      }
    });

    /** Read filter state from the URL hash (`#sort=year&source=github&…`).
     *  Returns a partial state map; the caller validates each value
     *  against the actual chips before applying. */
    function readHash(): Record<string, string> {
      const raw = window.location.hash.replace(/^#/, '');
      return Object.fromEntries(new URLSearchParams(raw));
    }

    /** Write the current filter state to the URL hash via replaceState
     *  (no browser-history entry per click). Default values are omitted
     *  so the canonical / unfiltered view stays at a clean URL. */
    function writeHash() {
      const params = new URLSearchParams();
      if (activeSource) params.set('source', activeSource);
      if (activeSort !== 'featured') params.set('sort', activeSort);
      if (activeTag) params.set('tag', activeTag);
      // Lang hash is omitted when the active filter matches the
      // ENVIRONMENT default (config-default, relaxed to "All" when the
      // browser advertises a non-default content-language). LocalStorage
      // is deliberately excluded from this check — including it would
      // let a saved preference suppress the hash, making URLs unshareable
      // (recipients wouldn't see the same view without their own LS
      // matching). The "all" sentinel is encoded explicitly so visitors
      // don't end up with a bare `lang=` that reads as "no value".
      if (activeLanguage !== environmentDefaultLanguage) {
        params.set('lang', activeLanguage === '' ? 'all' : activeLanguage);
      }
      if (activeStatus) params.set('status', activeStatus);
      if (shown >= cards.length && cards.length > pageSize) params.set('show-all', '1');
      if (overflowExpanded) params.set('tags-expanded', '1');
      const s = params.toString();
      const url = `${location.pathname}${location.search}${s ? '#' + s : ''}`;
      history.replaceState(null, '', url);
    }

    // Apply initial state from the hash before the first render so the
    // page lands in the requested state without a visible filter flicker.
    const initial = readHash();
    if (initial.source && sourceChips.some((c) => c.dataset.filterSource === initial.source)) {
      activeSource = initial.source;
      sourceChips.forEach((c) => {
        c.setAttribute('aria-pressed', String((c.dataset.filterSource ?? '') === activeSource));
      });
    }
    if (initial.sort && (['featured', 'popularity', 'year'] as Sort[]).includes(initial.sort as Sort)) {
      activeSort = initial.sort as Sort;
      sortChips.forEach((c) => {
        c.setAttribute('aria-pressed', String(c.dataset.filterSort === activeSort));
      });
    }
    // Language: hash value (if valid) wins over the configured default.
    // Unknown/missing language codes silently fall back to the default.
    // The explicit string 'all' in the URL maps to the empty "show all
    // languages" sentinel — symmetric with writeHash() above.
    const langKeys = new Set(languageChips.map((c) => c.dataset.filterLanguage ?? ''));
    if (typeof initial.lang === 'string') {
      const lang = initial.lang === 'all' ? '' : initial.lang;
      if (langKeys.has(lang)) activeLanguage = lang;
    }
    languageChips.forEach((c) => {
      c.setAttribute('aria-pressed', String((c.dataset.filterLanguage ?? '') === activeLanguage));
    });
    const VALID_STATUSES: Status[] = ['live', 'retired', 'updated'];
    if (typeof initial.status === 'string' && (VALID_STATUSES as string[]).includes(initial.status)) {
      activeStatus = initial.status as Status;
    }
    statusChips.forEach((c) => {
      c.setAttribute('aria-pressed', String((c.dataset.filterStatus ?? '') === activeStatus));
    });
    if (initial['tags-expanded'] === '1' && tagToggle) {
      overflowExpanded = true;
      const overflowCount = parseInt(tagToggle.dataset.overflowCount ?? '0', 10);
      tagToggle.setAttribute('aria-expanded', 'true');
      tagToggle.textContent = 'Fewer tags';
      void overflowCount;
    }
    refreshTagCounts();
    // Tag validation runs after refreshTagCounts because chip visibility
    // depends on the active source — a tag that doesn't appear under the
    // current source is silently dropped.
    if (initial.tag) {
      const chip = tagChips.find((c) => c.dataset.filterTag === initial.tag);
      if (chip && !chip.hasAttribute('hidden')) {
        activeTag = initial.tag;
        tagChips.forEach((c) => {
          c.setAttribute('aria-pressed', String((c.dataset.filterTag ?? '') === activeTag));
        });
      }
    }
    if (initial['show-all'] === '1') shown = cards.length;

    applyFilter();

    /** Bind a click handler to a Status chip in the additive style of
     *  the rest of the filter rows. Used both for SSR-rendered chips
     *  during init and dynamically-injected chips (e.g. "Updated"). */
    function bindStatusChip(chip: HTMLButtonElement) {
      chip.addEventListener('click', () => {
        const val = (chip.dataset.filterStatus ?? '') as Status;
        setStatus(val === activeStatus ? '' : val);
      });
    }

    /** Build the Status row from scratch when SSR didn't render one
     *  (no retired projects), so the dynamically-discovered "Updated"
     *  chip has somewhere to live. Mirrors the markup the Astro
     *  template emits when the row is server-rendered. */
    function ensureStatusRow(): HTMLElement {
      let row = root!.querySelector<HTMLElement>('.filter-row--status');
      if (row) return row;
      row = document.createElement('div');
      row.className = 'filter-row filter-row--status';
      row.setAttribute('aria-label', 'Filter by status');
      const total = cards.length;
      row.innerHTML = `
        <span class="filter-label">Status</span>
        <div class="filter-chips">
          <button type="button" class="filter-chip" data-filter-status="" aria-pressed="true">All <span class="filter-count">${total}</span></button>
        </div>
      `;
      // Slot the new row immediately before the Sort row so the layout
      // matches the SSR-rendered case.
      const sortRow = root!.querySelector('.filter-row--sort');
      sortRow?.parentNode?.insertBefore(row, sortRow);
      const allChip = row.querySelector<HTMLButtonElement>('[data-filter-status=""]')!;
      bindStatusChip(allChip);
      return row;
    }

    /** Ensure an "Updated" chip exists in the Status row, with the
     *  current count of updated cards. Called whenever the diff
     *  machinery (real or demo) finishes injecting card chips. */
    function refreshUpdatedChip(): void {
      const updatedCount = cards.filter((c) => c.dataset.updated === '1').length;
      const existing = root!.querySelector<HTMLButtonElement>('[data-filter-status="updated"]');
      if (updatedCount === 0) {
        // No updates → drop the chip (and reset filter if it was active).
        if (existing) existing.remove();
        statusChips = Array.from(root!.querySelectorAll<HTMLButtonElement>('[data-filter-status]'));
        if (activeStatus === 'updated') setStatus('');
        return;
      }
      const row = ensureStatusRow();
      if (existing) {
        const countEl = existing.querySelector<HTMLElement>('.filter-count');
        if (countEl) countEl.textContent = String(updatedCount);
      } else {
        const strip = row.querySelector<HTMLElement>('.filter-chips');
        if (strip) {
          const chip = document.createElement('button');
          chip.type = 'button';
          chip.className = 'filter-chip';
          chip.dataset.filterStatus = 'updated';
          chip.setAttribute('aria-pressed', String(activeStatus === 'updated'));
          chip.innerHTML = `Updated <span class="filter-count">${updatedCount}</span>`;
          strip.appendChild(chip);
          bindStatusChip(chip);
        }
      }
      statusChips = Array.from(root!.querySelectorAll<HTMLButtonElement>('[data-filter-status]'));
      if (initial.status === 'updated' && activeStatus !== 'updated') {
        setStatus('updated');
      } else {
        applyFilter();
      }
    }

    document.addEventListener('dashboard:updates-applied', refreshUpdatedChip);
    // Demo / real diff-stats may have run BEFORE this script registered
    // its listener (script order isn't guaranteed). Check once at init.
    refreshUpdatedChip();
  });
</script>
