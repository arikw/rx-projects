---
import config from '../lib/load-config';
import { loadProjects, getProfiles } from '../lib/load-projects';
import { resolveFavicon } from '../lib/resolve-favicon';

interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  author?: string;
}

const { title, description, ogType = 'website', author = config.user.name } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// Ensure the loader has run so `getProfiles()` is populated — loadProjects is
// memoised, so this just hits the cached result on subsequent pages.
await loadProjects();
const faviconLinks = await resolveFavicon(getProfiles());
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Apply stored theme before CSS paints to avoid a flash of the wrong
     scheme on reload. Runs synchronously; safe to fail. -->
<script is:inline>
  (function () {
    try {
      var t = localStorage.getItem('theme');
      if (t === 'dark' || t === 'light') {
        document.documentElement.setAttribute('data-theme', t);
      }
    } catch (e) {
      /* storage blocked — fall back to system preference */
    }
  })();
</script>

<link rel="canonical" href={canonicalURL} />
{faviconLinks.map((f) => (
  <link rel={f.rel} type={f.type} sizes={f.sizes} href={f.href} />
))}

<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={author} />

<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={config.meta.siteTitle} />

<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />

<meta name="robots" content="index,follow" />
