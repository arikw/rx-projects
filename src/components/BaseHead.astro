---
import config from '../lib/load-config';
import { loadProjects, getProfiles } from '../lib/load-projects';
import { resolveFavicon } from '../lib/resolve-favicon';

interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  author?: string;
  /** Absolute or root-relative URL for the social-share image
   *  (og:image / twitter:image). Resolved against `Astro.site`, so a
   *  `/projects/foo.png` becomes `https://your-site/projects/foo.png` —
   *  WhatsApp / Slack / LinkedIn crawl images only via absolute URLs.
   *  Falls back to `config.meta.ogImage` when the page doesn't
   *  supply one; both being absent simply omits the image meta
   *  block (and `twitter:card` stays as the smaller `summary`). */
  image?: string;
  /** Alt text for the social-share image. Defaults to `title` when
   *  omitted. */
  imageAlt?: string;
}

const { title, description, ogType = 'website', author = config.user.name, image, imageAlt } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

/** Resolve a possibly-relative URL to an absolute one against the
 *  site origin. Social crawlers (WhatsApp especially) refuse to
 *  fetch root-relative paths in og:image, so we always emit absolute.
 *  Rejects `data:` URIs outright — WhatsApp / Slack / LinkedIn can't
 *  fetch them, and several projects use emoji-SVG `data:` placeholders
 *  as fallback icons. Returning undefined here lets the caller fall
 *  through to `config.meta.ogImage` (or omit the meta block entirely
 *  if both are absent). */
function toAbsoluteSocialUrl(u: string | undefined): string | undefined {
  if (!u) return undefined;
  if (u.startsWith('data:')) return undefined;
  try {
    return new URL(u, Astro.site).toString();
  } catch {
    return undefined;
  }
}
const socialImage = toAbsoluteSocialUrl(image) ?? toAbsoluteSocialUrl(config.meta.ogImage);
const socialImageAlt = imageAlt ?? title;
// Twitter card variant: `summary_large_image` shows a full-width image
// preview when one is available; `summary` is the small thumbnail
// fallback for image-less pages. WhatsApp / Slack / LinkedIn / Discord
// ignore this property entirely — they read og:image.
const twitterCard = socialImage ? 'summary_large_image' : 'summary';
// Ensure the loader has run so `getProfiles()` is populated — loadProjects is
// memoised, so this just hits the cached result on subsequent pages.
await loadProjects();
const faviconLinks = await resolveFavicon(getProfiles());

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const themeColor = config.meta.themeColor ?? '#1f1f23';
const shortName = config.meta.shortName ?? config.meta.siteTitle;
// Service worker is opt-out via config and skipped in dev (HMR conflicts).
const swEnabled = config.meta.serviceWorker !== false && import.meta.env.PROD;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Apply stored theme before CSS paints to avoid a flash of the wrong
     scheme on reload. Visitor's stored override (localStorage) always
     wins. When no override exists, fall back to config.ui.defaultTheme
     (`'auto'`/`'light'`/`'dark'`) — `'auto'` defers to the OS
     `prefers-color-scheme` (no `data-theme` attribute set; CSS picks
     the scheme from `:root`). Runs synchronously; safe to fail. -->
<script is:inline define:vars={{ siteDefaultTheme: config.ui.defaultTheme ?? 'auto' }}>
  (function () {
    var theme = null;
    try {
      var stored = localStorage.getItem('theme');
      if (stored === 'dark' || stored === 'light') theme = stored;
    } catch (e) {
      /* storage blocked — no override available */
    }
    if (!theme && (siteDefaultTheme === 'dark' || siteDefaultTheme === 'light')) {
      theme = siteDefaultTheme;
    }
    if (theme) {
      document.documentElement.setAttribute('data-theme', theme);
    }
  })();
</script>

<link rel="canonical" href={canonicalURL} />
{faviconLinks.map((f) => (
  <link rel={f.rel} type={f.type} sizes={f.sizes} href={f.href} />
))}

<!-- PWA manifest. The endpoint at /<base>/manifest.webmanifest is built
     from projects.config.ts (name, short_name, icons, theme/bg colour). -->
<link rel="manifest" href={`${base}manifest.webmanifest`} />
<meta name="theme-color" content={themeColor} />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-title" content={shortName} />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />

{swEnabled && (
  <script is:inline define:vars={{ swPath: `${base}sw.js`, scope: base }}>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register(swPath, { scope }).catch(() => {});
      });
    }
  </script>
)}

<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={author} />

<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={config.meta.siteTitle} />
{socialImage && (
  <>
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:alt" content={socialImageAlt} />
  </>
)}

<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{socialImage && (
  <>
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
  </>
)}

<meta name="robots" content="index,follow" />
