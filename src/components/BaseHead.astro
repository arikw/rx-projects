---
import config from '../lib/load-config';
import { loadProjects, getProfiles } from '../lib/load-projects';
import { resolveFavicon } from '../lib/resolve-favicon';

interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  author?: string;
}

const { title, description, ogType = 'website', author = config.user.name } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// Ensure the loader has run so `getProfiles()` is populated — loadProjects is
// memoised, so this just hits the cached result on subsequent pages.
await loadProjects();
const faviconLinks = await resolveFavicon(getProfiles());

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const themeColor = config.meta.themeColor ?? '#1f1f23';
const shortName = config.meta.shortName ?? config.meta.siteTitle;
// Service worker is opt-out via config and skipped in dev (HMR conflicts).
const swEnabled = config.meta.serviceWorker !== false && import.meta.env.PROD;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Apply stored theme before CSS paints to avoid a flash of the wrong
     scheme on reload. Visitor's stored override (localStorage) always
     wins. When no override exists, fall back to config.ui.defaultTheme
     (`'auto'`/`'light'`/`'dark'`) — `'auto'` defers to the OS
     `prefers-color-scheme` (no `data-theme` attribute set; CSS picks
     the scheme from `:root`). Runs synchronously; safe to fail. -->
<script is:inline define:vars={{ siteDefaultTheme: config.ui.defaultTheme ?? 'auto' }}>
  (function () {
    var theme = null;
    try {
      var stored = localStorage.getItem('theme');
      if (stored === 'dark' || stored === 'light') theme = stored;
    } catch (e) {
      /* storage blocked — no override available */
    }
    if (!theme && (siteDefaultTheme === 'dark' || siteDefaultTheme === 'light')) {
      theme = siteDefaultTheme;
    }
    if (theme) {
      document.documentElement.setAttribute('data-theme', theme);
    }
  })();
</script>

<link rel="canonical" href={canonicalURL} />
{faviconLinks.map((f) => (
  <link rel={f.rel} type={f.type} sizes={f.sizes} href={f.href} />
))}

<!-- PWA manifest. The endpoint at /<base>/manifest.webmanifest is built
     from projects.config.ts (name, short_name, icons, theme/bg colour). -->
<link rel="manifest" href={`${base}manifest.webmanifest`} />
<meta name="theme-color" content={themeColor} />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-title" content={shortName} />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />

{swEnabled && (
  <script is:inline define:vars={{ swPath: `${base}sw.js`, scope: base }}>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register(swPath, { scope }).catch(() => {});
      });
    }
  </script>
)}

<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={author} />

<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={config.meta.siteTitle} />

<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />

<meta name="robots" content="index,follow" />
