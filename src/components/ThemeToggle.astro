---
// Theme toggle — manual override of the system colour-scheme preference.
//
// Initial state (no localStorage entry) → follows `prefers-color-scheme`.
// First click → writes `theme` to localStorage and pins the choice on
// `<html data-theme="…">`. The pre-CSS inline script in BaseHead applies
// the stored value before paint to avoid a flash of the wrong theme.
---
<button
  type="button"
  class="theme-toggle"
  aria-label="Switch theme"
  title="Switch theme"
  data-theme-toggle
>
  <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true">
    <path
      d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"
      fill="currentColor"
    />
  </svg>
  <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="4" fill="currentColor" />
    <g stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none">
      <line x1="12" y1="2" x2="12" y2="5" />
      <line x1="12" y1="19" x2="12" y2="22" />
      <line x1="2" y1="12" x2="5" y2="12" />
      <line x1="19" y1="12" x2="22" y2="12" />
      <line x1="4.93" y1="4.93" x2="7.05" y2="7.05" />
      <line x1="16.95" y1="16.95" x2="19.07" y2="19.07" />
      <line x1="4.93" y1="19.07" x2="7.05" y2="16.95" />
      <line x1="16.95" y1="7.05" x2="19.07" y2="4.93" />
    </g>
  </svg>
</button>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const html = document.documentElement;
      // Effective current theme: explicit override wins, otherwise system pref.
      const current =
        html.getAttribute('data-theme') ??
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      const next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      try {
        localStorage.setItem('theme', next);
      } catch {
        /* private mode / storage disabled — toggle still works for this session */
      }
    });
  });
</script>
