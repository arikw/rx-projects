---
import type { CarouselReview } from '../lib/pick-reviews';
import { sourceLabel } from '../lib/source-label';

interface Props {
  reviews: CarouselReview[];
  /** Auto-advance interval in ms. */
  interval?: number;
}
const { reviews, interval = 6000 } = Astro.props;

// Per-slide accent — pull from the project's iconColor so the carousel
// inherits the same colour rhythm the icon-only cards use.
function tintFor(r: CarouselReview): string {
  return r.projectIconColor ?? 'var(--accent)';
}

const fmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
});
function formatDate(ts?: string): string | null {
  if (!ts) return null;
  const d = new Date(ts);
  if (Number.isNaN(d.getTime())) return null;
  return fmt.format(d);
}
---
{reviews.length > 0 && (
  <section
    class="review-carousel"
    aria-label="Recent positive reviews"
    data-interval={interval}
  >
    <div class="review-stage">
      {reviews.map((r, i) => {
        const dateLabel = formatDate(r.ts);
        const rating = typeof r.rating === 'number' && r.rating > 0
          ? Math.min(5, Math.max(0, Math.round(r.rating)))
          : null;
        return (
          <article
            class="review-slide"
            data-index={i}
            data-state={i === 0 ? 'active' : ''}
            aria-current={i === 0 ? 'true' : 'false'}
            aria-hidden={i === 0 ? 'false' : 'true'}
            style={`--card-accent: ${tintFor(r)}`}
          >
            <div class="review-slide-mark" aria-hidden="true">&ldquo;</div>
            <blockquote class="review-slide-body">{r.body}</blockquote>

            {rating !== null && (
              <div class="review-slide-rating" aria-label={`${rating} out of 5 stars`}>
                <span class="review-slide-rating-filled">{'★'.repeat(rating)}</span>
                <span class="review-slide-rating-empty">{'★'.repeat(5 - rating)}</span>
              </div>
            )}

            <footer class="review-slide-foot">
              <a
                class="review-slide-source"
                href={r.projectUrl}
                target="_blank"
                rel="noopener"
                title={`Open ${r.projectTitle}`}
              >
                {r.projectIcon ? (
                  <img
                    class="review-slide-source-icon"
                    src={r.projectIcon}
                    alt=""
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <span
                    class="review-slide-source-icon review-slide-source-icon--placeholder"
                    aria-hidden="true"
                  />
                )}
                <span class="review-slide-source-title">{r.projectTitle}</span>
              </a>
              <span class="review-slide-meta">
                {r.source && (
                  <span class="review-slide-source-tag">via {sourceLabel(r.source)}</span>
                )}
                {dateLabel && (
                  <>
                    {r.source && <span class="review-slide-meta-sep" aria-hidden="true">·</span>}
                    <time class="review-slide-date" datetime={r.ts}>{dateLabel}</time>
                  </>
                )}
              </span>
            </footer>
          </article>
        );
      })}
    </div>

    {reviews.length > 1 && (
      <nav class="review-dots" aria-label="Choose a review">
        {reviews.map((_, i) => (
          <button
            type="button"
            class="review-dot"
            data-jump={i}
            aria-label={`Show review ${i + 1} of ${reviews.length}`}
            aria-current={i === 0 ? 'true' : 'false'}
          />
        ))}
      </nav>
    )}
  </section>
)}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll<HTMLElement>('.review-carousel').forEach((root) => {
      const slides = Array.from(root.querySelectorAll<HTMLElement>('.review-slide'));
      const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('.review-dot'));
      if (slides.length < 2) return;

      const interval = parseInt(root.dataset.interval ?? '6000', 10);
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let current = 0;
      let paused = false;
      let timer: number | null = null;

      function show(next: number) {
        const idx = ((next % slides.length) + slides.length) % slides.length;
        if (idx === current) return;

        // Outgoing: slide-out animation (toward the left).
        const outgoing = slides[current];
        outgoing.dataset.state = 'leaving';
        outgoing.setAttribute('aria-current', 'false');
        outgoing.setAttribute('aria-hidden', 'true');

        // Incoming: clear state, force reflow so the browser re-evaluates,
        // then set 'active' to restart the slide-in animation from the right.
        const incoming = slides[idx];
        incoming.dataset.state = '';
        // eslint-disable-next-line @typescript-eslint/no-unused-expressions
        void incoming.offsetWidth;
        incoming.dataset.state = 'active';
        incoming.setAttribute('aria-current', 'true');
        incoming.setAttribute('aria-hidden', 'false');

        if (dots.length) {
          dots[current]?.setAttribute('aria-current', 'false');
          dots[idx]?.setAttribute('aria-current', 'true');
        }
        current = idx;
      }
      function tick() { if (!paused) show(current + 1); }
      function startTimer() {
        if (reduceMotion || timer != null) return;
        timer = window.setInterval(tick, interval);
      }
      function stopTimer() {
        if (timer != null) { clearInterval(timer); timer = null; }
      }
      function resetTimer() { stopTimer(); startTimer(); }

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const i = parseInt(dot.dataset.jump ?? '0', 10);
          show(i);
          resetTimer();
        });
      });

      root.addEventListener('mouseenter', () => { paused = true; });
      root.addEventListener('mouseleave', () => { paused = false; });
      root.addEventListener('focusin', () => { paused = true; });
      root.addEventListener('focusout', () => { paused = false; });

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stopTimer(); else startTimer();
      });

      startTimer();
    });
  });
</script>
