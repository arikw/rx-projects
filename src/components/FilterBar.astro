---
interface SourceEntry {
  key: string;
  label: string;
  count: number;
}
interface TagEntry {
  name: string;
  count: number;
}
interface LanguageEntry {
  key: string;
  label: string;
  count: number;
}
interface StatusEntry {
  key: 'live' | 'retired';
  label: string;
  count: number;
}
interface Props {
  totalCount: number;
  sources: SourceEntry[];
  primaryTags: TagEntry[];
  overflowTags: TagEntry[];
  /** Renders a Language filter row when this is non-empty. The caller
   *  populates it only when at least one non-default-language project
   *  exists; otherwise the row is hidden entirely. */
  languages?: LanguageEntry[];
  /** Renders a Status filter row when this is non-empty. The caller
   *  populates it only when at least one retired project exists. */
  statuses?: StatusEntry[];
}
const { totalCount, sources, primaryTags, overflowTags, languages = [], statuses = [] } = Astro.props;
const hasOverflow = overflowTags.length > 0;
const hasTags = primaryTags.length > 0 || hasOverflow;
const hasLanguages = languages.length > 0;
const hasStatuses = statuses.length > 0;
---
<div class="filter-bar" role="group" aria-label="Filter and sort projects">
  <div class="filter-row" aria-label="Filter by source">
    <span class="filter-label">Source</span>
    <div class="filter-chips">
      <button
        type="button"
        class="filter-chip"
        data-filter-source=""
        aria-pressed="true"
      >
        All <span class="filter-count">{totalCount}</span>
      </button>
      {sources.map(({ key, label, count }) => (
        <button
          type="button"
          class="filter-chip"
          data-filter-source={key}
          aria-pressed="false"
        >
          {label} <span class="filter-count">{count}</span>
        </button>
      ))}
    </div>
  </div>
  {hasTags && (
    <div class="filter-row filter-row--tags" aria-label="Filter by tag">
      <span class="filter-label">Tag</span>
      <div class="filter-chips">
        <button
          type="button"
          class="filter-chip"
          data-filter-tag=""
          aria-pressed="true"
        >
          All <span class="filter-count" data-tag-count-total>{totalCount}</span>
        </button>
        {primaryTags.map(({ name, count }) => (
          <button
            type="button"
            class="filter-chip filter-chip--tag"
            data-filter-tag={name}
            data-base-count={count}
            aria-pressed="false"
          >
            {name} <span class="filter-count">{count}</span>
          </button>
        ))}
        {overflowTags.map(({ name, count }) => (
          <button
            type="button"
            class="filter-chip filter-chip--tag filter-chip--overflow"
            data-filter-tag={name}
            data-base-count={count}
            aria-pressed="false"
            hidden
          >
            {name} <span class="filter-count">{count}</span>
          </button>
        ))}
        {hasOverflow && (
          <button
            type="button"
            class="filter-chip filter-chip-toggle"
            data-tag-toggle
            aria-expanded="false"
            data-overflow-count={overflowTags.length}
          >
            + {overflowTags.length} more
          </button>
        )}
      </div>
    </div>
  )}
  {hasLanguages && (
    <div class="filter-row filter-row--language" aria-label="Filter by language">
      <span class="filter-label">Language</span>
      <div class="filter-chips">
        <button
          type="button"
          class="filter-chip"
          data-filter-language=""
          aria-pressed="true"
        >
          All <span class="filter-count">{totalCount}</span>
        </button>
        {languages.map(({ key, label, count }) => (
          <button
            type="button"
            class="filter-chip"
            data-filter-language={key}
            aria-pressed="false"
          >
            {label} <span class="filter-count">{count}</span>
          </button>
        ))}
      </div>
    </div>
  )}
  {hasStatuses && (
    <div class="filter-row filter-row--status" aria-label="Filter by status">
      <span class="filter-label">Status</span>
      <div class="filter-chips">
        <button
          type="button"
          class="filter-chip"
          data-filter-status=""
          aria-pressed="true"
        >
          All <span class="filter-count">{totalCount}</span>
        </button>
        {statuses.map(({ key, label, count }) => (
          <button
            type="button"
            class="filter-chip"
            data-filter-status={key}
            aria-pressed="false"
          >
            {label} <span class="filter-count">{count}</span>
          </button>
        ))}
      </div>
    </div>
  )}
  <div class="filter-row filter-row--sort" aria-label="Sort">
    <span class="filter-label">Sort</span>
    <div class="filter-chips">
      <button
        type="button"
        class="filter-chip"
        data-filter-sort="featured"
        aria-pressed="true"
      >Featured</button>
      <button
        type="button"
        class="filter-chip"
        data-filter-sort="popularity"
        aria-pressed="false"
      >Popularity</button>
      <button
        type="button"
        class="filter-chip"
        data-filter-sort="year"
        aria-pressed="false"
      >Year</button>
    </div>
  </div>
</div>

<script>
  // Toggle the directional scroll-fade classes on each .filter-chips
  // strip based on its actual scroll position. The CSS reads these
  // classes to decide which edge gets a gradient — no fade when the
  // edge has nothing scrollable behind it, no fade at all when the
  // content fits within the visible width.
  function updateScrollFades(el: HTMLElement) {
    const tol = 1; // sub-pixel tolerance
    const atStart = el.scrollLeft <= tol;
    const atEnd = el.scrollLeft + el.clientWidth >= el.scrollWidth - tol;
    el.classList.toggle('show-left-fade', !atStart);
    el.classList.toggle('show-right-fade', !atEnd);
  }

  function initScrollFades() {
    const strips = document.querySelectorAll<HTMLElement>('.filter-chips');
    strips.forEach((s) => {
      updateScrollFades(s);
      s.addEventListener('scroll', () => updateScrollFades(s), { passive: true });
    });
    // Re-check on resize: viewport change can flip a strip between
    // "fits" and "overflows" states.
    window.addEventListener('resize', () => strips.forEach(updateScrollFades));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollFades);
  } else {
    initScrollFades();
  }
</script>
