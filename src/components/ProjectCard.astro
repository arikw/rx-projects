---
import type { Project, ProjectSource } from '../types/project';
import { formatStat } from '../lib/aggregate-stats';
import { sourceLabel } from '../lib/source-label';
import ProjectThumb from './ProjectThumb.astro';

interface Props {
  project: Project;
  size?: 'compact' | 'featured';
}
const { project: p, size = 'compact' } = Astro.props;
const base = import.meta.env.BASE_URL;

type CardStat = { text: string; title: string; icon?: 'download' | 'users' };
const stats: CardStat[] = [];
if (p.stats.stars !== undefined && p.stats.stars > 0)
  stats.push({ text: `★ ${formatStat(p.stats.stars)}`, title: 'GitHub stars' });
if (p.stats.users !== undefined && p.stats.users > 0)
  stats.push({ text: `${formatStat(p.stats.users)} weekly users`, title: 'Weekly active users (Chrome Web Store)', icon: 'users' });
if (p.stats.pulls !== undefined && p.stats.pulls > 0)
  stats.push({ text: `${formatStat(p.stats.pulls)} pulls`, title: 'Docker Hub pulls (all-time)', icon: 'download' });
if (p.stats.gnomeDownloads !== undefined && p.stats.gnomeDownloads > 0)
  stats.push({ text: `${formatStat(p.stats.gnomeDownloads)} downloads`, title: 'GNOME Extensions downloads (all-time)', icon: 'download' });
if (p.stats.downloadsAllTime !== undefined && p.stats.downloadsAllTime > 0)
  stats.push({ text: `${formatStat(p.stats.downloadsAllTime)} downloads`, title: 'npm downloads (all-time)', icon: 'download' });
if (p.stats.downloadsMonthly !== undefined && p.stats.downloadsMonthly > 0)
  stats.push({ text: `${formatStat(p.stats.downloadsMonthly)}/mo`, title: 'npm downloads in the last 30 days', icon: 'download' });
const cardSources = p.sources ?? [p.source];

// Friendly chip labels, deduped — so an AppBrain+APKPure card shows one
// "Android app" chip rather than two raw source keys.
const seenSourceLabels = new Set<string>();
const sourceChips: { s: ProjectSource; label: string }[] = [];
for (const s of cardSources) {
  const label = sourceLabel(s);
  if (seenSourceLabels.has(label)) continue;
  seenSourceLabels.add(label);
  sourceChips.push({ s, label });
}

if (p.stats.installs !== undefined && p.stats.installs > 0) {
  // AppBrain wins the merge, so installs is the Google Play tier when present;
  // otherwise it's APKPure's own mirror download count. Label honestly.
  const fromPlay = cardSources.includes('appbrain');
  stats.push({
    text: fromPlay ? `${formatStat(p.stats.installs)}+ installs` : `${formatStat(p.stats.installs)} downloads`,
    title: fromPlay ? 'Google Play installs (10,000+ tier)' : 'APKPure downloads',
    icon: 'download',
  });
}
if (p.stats.rating !== undefined && p.stats.ratingCount) {
  const ratingStore = cardSources.includes('chrome') ? 'Chrome Web Store' : 'Google Play';
  stats.push({ text: `${p.stats.rating.toFixed(1)}★ (${formatStat(p.stats.ratingCount)})`, title: `${ratingStore} rating (number of ratings)` });
}

const detailHref = p.hasDetail ? `${base}${p.id}/` : null;

// Only badge open-source when the source chip doesn't already imply it
// (github/npm are open-source by nature). Keeps the badge a signal, not noise.
const showOssBadge = !!p.openSource && p.source !== 'github' && p.source !== 'npm';

// Project's own website, if it has one distinct from its listing URL.
const homepage = p.homepage && p.homepage !== p.url ? p.homepage : null;
const homepageHost = homepage ? homepage.replace(/^https?:\/\//, '').replace(/\/$/, '') : null;
---
<article class={`card card--${size}`} data-tags={p.tags.join(',')} data-source={p.source}>
  <ProjectThumb project={p} />
  <header class="card-head">
    <a class="card-title" href={p.url} rel="noopener" target="_blank">
      <h3>{p.title}</h3>
      <span class="card-arrow" aria-hidden="true">↗</span>
    </a>
    <span class="card-sources">
      {sourceChips.map(({ s, label }) => (
        <span class={`card-source card-source--${s}`}>{label}</span>
      ))}
    </span>
  </header>

  {(p.kind || showOssBadge || homepage) && (
    <p class="card-badges">
      {p.kind && <span class={`card-badge card-badge--kind card-badge--kind-${p.kind}`}>{p.kind}</span>}
      {showOssBadge && (
        <a
          class="card-badge card-badge--oss"
          href={p.sourceUrl ?? p.url}
          target="_blank"
          rel="noopener"
          title={p.sourceUrl ? `Source: ${p.sourceUrl}` : 'Open source'}
        >open source</a>
      )}
      {homepage && (
        <a
          class="card-badge card-badge--site"
          href={homepage}
          target="_blank"
          rel="noopener"
          title={homepage}
        >{homepageHost} ↗</a>
      )}
    </p>
  )}

  {p.description && <p class="card-desc">{p.description}</p>}

  {stats.length > 0 && (
    <p class="card-stats">
      {stats.map((s) => (
        <span class="card-stat" title={s.title}>
          {s.icon === 'download' && (
            <svg class="stat-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M5 20h14v-2H5v2zM19 9h-4V3H9v6H5l7 7 7-7z" />
            </svg>
          )}
          {s.icon === 'users' && (
            <svg class="stat-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
            </svg>
          )}
          {s.text}
        </span>
      ))}
    </p>
  )}

  {p.tags.length > 0 && (
    <p class="card-tags">
      {p.tags.slice(0, 4).map((t) => <span class="card-tag">{t}</span>)}
    </p>
  )}

  {detailHref && (
    <a class="card-detail-link" href={detailHref}>Details →</a>
  )}
</article>
