---
import type { Project } from '../types/project';
import { formatStat } from '../lib/aggregate-stats';
import { featuredScore } from '../lib/featured-score';
import { resolveTitleHref } from '../lib/title-href';
import ProjectThumb from './ProjectThumb.astro';
import CardSources from './CardSources.astro';

interface Props {
  project: Project;
  size?: 'compact' | 'featured';
  /** Space-separated source-group keys for the source-filter (e.g. "github npm"). */
  sourceGroups?: string;
  /** Space-separated tag list for the tag-filter chips. */
  tagList?: string;
  /** Content language code ('en' for the default; 'he', … for non-default).
   *  Used by the client-side language filter. */
  contentLanguage?: string;
  /** 0-based index in config.featured when this project is pinned. Drives
   *  the client-side "Featured" sort. Omit for non-featured cards. */
  featuredRank?: number;
  /** Where the year/year-range is rendered:
   *   - 'kicker' — small uppercase kicker line above the title; pairs with
   *     the bold-title + accent-rule editorial treatment driven by the
   *     `data-year-style="kicker"` selector in global.css. Default.
   *   - 'inline' — legacy mode: year appears as a stat chip in the stats row.
   *  For retired projects with a known last-active year, both modes render
   *  the range `YYYY–YYYY`. */
  yearStyle?: 'kicker' | 'inline';
  /** Where the source/platform link chips are rendered:
   *   - 'footer' — bottom of the card with a divider rule above (default).
   *   - 'title'  — legacy mode: beside the title in `.card-head`. */
  chipsLayout?: 'footer' | 'title';
}
const { project: p, size = 'compact', sourceGroups = '', tagList = '', contentLanguage = 'en', featuredRank, yearStyle = 'kicker', chipsLayout = 'footer' } = Astro.props;

// Display string for the year slot. Retired projects with a known last
// activity render as `YYYY–YYYY` (active lifespan); live projects render
// just the first-released year (the "most recent" date isn't meaningful
// when the project is still moving).
//
// Source precedence for the end-year: an explicit `retiredAt` (set on
// manual entries with a known sunset date) wins, falling back to
// `updatedAt` (computed from mirror `asOf` timestamps).
const lastYearSource = p.retiredAt ?? p.updatedAt;
const lastYear = lastYearSource ? new Date(lastYearSource).getUTCFullYear() : undefined;
// Retired projects always render the range when a last-seen year is known
// — even when start == end (e.g. a Chrome extension that lived only a few
// weeks in 2017 shows `2017–2017`). The visible duplication is the point:
// it signals retirement at a glance without needing a separate badge.
const yearLabel = !p.year ? null : (
  p.retired && lastYear
    ? `${p.year}–${lastYear}`
    : String(p.year)
);
const base = import.meta.env.BASE_URL;

// Popularity signal for client-side "sort by popularity" — raw,
// uncomposed total count (matches the user's mental model of
// "biggest numbers first" when they pick that sort explicitly).
const popularity =
  (p.stats.stars ?? 0) +
  (p.stats.downloads ?? 0) +
  (p.stats.installs?.value ?? 0) +
  (p.stats.users ?? 0);
// Featured-sort score for non-explicit-featured projects. Weighted
// quality score (installable + visual richness + recency + log-
// popularity, retired discount, 0-effort cap) defined in
// featured-score.ts and used by index.astro's SSR sort too.
const featured = featuredScore(p);

// Card stats: number + icon only (no descriptive words). The hero stats
// act as a legend — same icons, full labels — so visitors learn the meaning
// once at the top, then read the cards as compact number rows.
type CardStat = { text: string; title: string; icon?: 'star' | 'download' | 'users' | 'past-users' | 'calendar' | 'dependents' };
const stats: CardStat[] = [];
const st = p.stats;
if (st.stars && st.stars > 0)
  stats.push({ text: formatStat(st.stars), title: 'Stars (GitHub + Docker Hub)', icon: 'star' });
// Active-users badge — appears on retired cards too, but with a tooltip
// that flags the number as a historical snapshot rather than a current
// headcount. (The hero "Active users" tile still excludes retired in
// aggregateStats, so the dashboard-level number stays a live total.)
if (st.users && st.users > 0)
  stats.push({
    text: formatStat(st.users),
    title: p.retired
      ? 'Past active users (historical snapshot)'
      : 'Weekly active users (Chrome Web Store)',
    icon: p.retired ? 'past-users' : 'users',
  });
if (st.downloads && st.downloads > 0)
  stats.push({ text: formatStat(st.downloads), title: 'Downloads / pulls (npm, Docker, GNOME, mirrors)', icon: 'download' });
if (st.downloadsMonthly && st.downloadsMonthly > 0)
  stats.push({ text: `${formatStat(st.downloadsMonthly)}/mo`, title: 'npm downloads in the last 30 days', icon: 'download' });
if (st.dependents && st.dependents > 0)
  stats.push({
    text: formatStat(st.dependents),
    title: st.dependents === 1
      ? '1 other npm package depends on this one'
      : `${st.dependents.toLocaleString('en')} other npm packages depend on this one`,
    icon: 'dependents',
  });
if (st.installs && st.installs.value > 0)
  stats.push({
    text: `${formatStat(st.installs.value)}${st.installs.exact ? '' : '+'}`,
    title: st.installs.exact
      ? 'Google Play installs (Play Console total)'
      : 'Google Play installs ("10,000+" tier)',
    icon: 'download',
  });
if (st.rating)
  stats.push({
    text: st.rating.count
      ? `${st.rating.average.toFixed(1)}★ (${formatStat(st.rating.count)})`
      : `${st.rating.average.toFixed(1)}★`,
    title: st.rating.count ? 'Store rating (number of ratings)' : 'Store rating',
  });
if (p.year && yearStyle === 'inline')
  stats.push({ text: yearLabel ?? String(p.year), title: p.retired && lastYear && lastYear > p.year
    ? `Active ${p.year}–${lastYear}`
    : `First released in ${p.year}`, icon: 'calendar' });

// Chip rendering lives in CardSources.astro — see that component for
// dedup-by-source-group, the homepage-chip resolver, and the markup.
const titleHref = resolveTitleHref(p);

const detailHref = p.hasDetail ? `${base}${p.id}/` : null;

---
<article
  class={`card card--${size}`}
  data-id={p.id}
  data-source-groups={sourceGroups}
  data-tags={tagList}
  data-content-language={contentLanguage}
  data-year={p.year ?? ''}
  data-popularity={popularity}
  data-featured-score={featured}
  data-featured-rank={featuredRank ?? ''}
  data-status={p.retired ? 'retired' : 'live'}
  data-year-style={yearStyle}
>
  <span class="card-new-ribbon" hidden>NEW</span>
  <div class="card-thumb-frame">
    <ProjectThumb project={p} />
    <span class="card-updated-chip" hidden></span>
  </div>
  <header class="card-head">
    {yearStyle === 'kicker' && yearLabel && (
      <p class="card-year-kicker" aria-label={p.retired && lastYear && lastYear > (p.year ?? 0)
        ? `Active ${p.year}–${lastYear}`
        : `First released in ${p.year}`}>
        <svg class="year-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z" />
        </svg>{yearLabel}
      </p>
    )}
    <a class="card-title" href={titleHref} rel="noopener" target="_blank">
      <h3>{p.title}</h3>
    </a>
    {chipsLayout === 'title' && <CardSources project={p} layout="title" />}
  </header>

  {p.description && <p class="card-desc">{p.description}</p>}

  {stats.length > 0 && (
    <p class="card-stats">
      {stats.map((s) => (
        <span class="card-stat" data-tooltip={s.title}>
          {s.icon === 'star' && (
            <svg class="stat-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
            </svg>
          )}
          {s.icon === 'download' && (
            <svg class="stat-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M5 20h14v-2H5v2zM19 9h-4V3H9v6H5l7 7 7-7z" />
            </svg>
          )}
          {s.icon === 'users' && (
            <svg class="stat-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
            </svg>
          )}
          {s.icon === 'past-users' && (
            <svg class="stat-icon" viewBox="0 0 24 24" aria-hidden="true">
              {/* Person silhouette nudged to the top-left so a clock
                  badge can sit at the bottom-right. The clock body is
                  redrawn over the silhouette so the two shapes don't
                  visually fuse. */}
              <path fill="currentColor" d="M9 11c2.21 0 4-1.79 4-4S11.21 3 9 3 5 4.79 5 7s1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h10v-2c0-1.32 0.4-2.55 1.08-3.59A14.6 14.6 0 0 0 9 13z"/>
              <circle cx="18" cy="17" r="5" fill="currentColor"/>
              <circle cx="18" cy="17" r="3.6" fill="var(--card-bg, #fff)"/>
              <path stroke="currentColor" stroke-width="1.3" stroke-linecap="round" fill="none" d="M18 14.8 V 17 L 19.8 17.8"/>
            </svg>
          )}
          {s.icon === 'calendar' && (
            <svg class="stat-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z" />
            </svg>
          )}
          {s.icon === 'dependents' && (
            <svg class="stat-icon" viewBox="0 0 24 24" aria-hidden="true">
              {/* Material "device_hub" — one node at the top branching to
                  three at the bottom. Reads as "N things depend on this". */}
              <path fill="currentColor" d="M17 16l-4-4V8.82C14.16 8.4 15 7.3 15 6c0-1.66-1.34-3-3-3S9 4.34 9 6c0 1.3.84 2.4 2 2.82V12l-4 4H3v5h5v-3.05l4-4.2 4 4.2V21h5v-5h-4z"/>
            </svg>
          )}
          {s.text}
        </span>
      ))}
    </p>
  )}

  {chipsLayout === 'footer' && <CardSources project={p} layout="footer" />}

  {detailHref && (
    <a class="card-detail-link" href={detailHref}>Details →</a>
  )}
</article>
