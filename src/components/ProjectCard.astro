---
import type { Project } from '../types/project';
import { formatStat } from '../lib/aggregate-stats';
import { sourceLabel } from '../lib/source-label';
import { getPlatformToSourceGroup } from '../connectors/_registry';
import ProjectThumb from './ProjectThumb.astro';

interface Props {
  project: Project;
  size?: 'compact' | 'featured';
  /** Space-separated source-group keys for the source-filter (e.g. "github npm"). */
  sourceGroups?: string;
  /** Space-separated tag list for the tag-filter chips. */
  tagList?: string;
  /** 0-based index in config.featured when this project is pinned. Drives
   *  the client-side "Featured" sort. Omit for non-featured cards. */
  featuredRank?: number;
}
const { project: p, size = 'compact', sourceGroups = '', tagList = '', featuredRank } = Astro.props;
const base = import.meta.env.BASE_URL;

// Popularity signal for client-side "sort by popularity" — same formula as
// the build-time default sort in index.astro so the order matches when the
// user toggles back from year sort.
const popularity =
  (p.stats.stars ?? 0) +
  (p.stats.downloads ?? 0) +
  (p.stats.installs?.value ?? 0) +
  (p.stats.users ?? 0);

// Card stats: number + icon only (no descriptive words). The hero stats
// act as a legend — same icons, full labels — so visitors learn the meaning
// once at the top, then read the cards as compact number rows.
type CardStat = { text: string; title: string; icon?: 'star' | 'download' | 'users' | 'calendar' };
const stats: CardStat[] = [];
const st = p.stats;
if (st.stars && st.stars > 0)
  stats.push({ text: formatStat(st.stars), title: 'Stars (GitHub + Docker Hub)', icon: 'star' });
if (st.users && st.users > 0)
  stats.push({ text: formatStat(st.users), title: 'Weekly active users (Chrome Web Store)', icon: 'users' });
if (st.downloads && st.downloads > 0)
  stats.push({ text: formatStat(st.downloads), title: 'Downloads / pulls (npm, Docker, GNOME, mirrors)', icon: 'download' });
if (st.downloadsMonthly && st.downloadsMonthly > 0)
  stats.push({ text: `${formatStat(st.downloadsMonthly)}/mo`, title: 'npm downloads in the last 30 days', icon: 'download' });
if (st.installs && st.installs.value > 0)
  stats.push({
    text: `${formatStat(st.installs.value)}${st.installs.exact ? '' : '+'}`,
    title: st.installs.exact
      ? 'Google Play installs (Play Console total)'
      : 'Google Play installs ("10,000+" tier)',
    icon: 'download',
  });
if (st.rating && st.rating.count)
  stats.push({ text: `${st.rating.average.toFixed(1)}★ (${formatStat(st.rating.count)})`, title: 'Store rating (number of ratings)' });
if (p.year)
  stats.push({ text: String(p.year), title: `First released in ${p.year}`, icon: 'calendar' });

// Friendly chip labels, deduped — e.g. a google-play + apkpure card shows one
// "Android app" chip rather than two raw platform keys. Each chip resolves
// to a clickable URL via project.sourceUrls (origin URL preferred, mirror
// URL as fallback when the origin is removed). Source→group map is derived
// from the registry.
const SOURCE_TO_GROUP: Record<string, string> = getPlatformToSourceGroup();
const seenSourceLabels = new Set<string>();
const sourceChips: { s: string; label: string; href?: string }[] = [];
for (const s of p.sources) {
  const label = sourceLabel(s);
  if (seenSourceLabels.has(label)) continue;
  seenSourceLabels.add(label);
  // Registered connector → use its source-group; one-off platforms (e.g.
  // `'firefox'` declared by a ManualProject.source) → look up their own
  // platform key directly. buildProjects stores sourceUrls under either,
  // so the chip becomes clickable for both cases.
  const group = SOURCE_TO_GROUP[s] ?? s;
  const href = p.sourceUrls?.[group];
  sourceChips.push({ s, label, href });
}

const detailHref = p.hasDetail ? `${base}${p.id}/` : null;

---
<article
  class={`card card--${size}`}
  data-source-groups={sourceGroups}
  data-tags={tagList}
  data-year={p.year ?? ''}
  data-popularity={popularity}
  data-featured-rank={featuredRank ?? ''}
>
  <ProjectThumb project={p} />
  <header class="card-head">
    <a class="card-title" href={p.url} rel="noopener" target="_blank">
      <h3>{p.title}</h3>
    </a>
    <span class="card-sources">
      {sourceChips.map(({ s, label, href }) => (
        href ? (
          <a
            class={`card-source card-source--${s}`}
            href={href}
            target="_blank"
            rel="noopener"
            title={href}
          >{label} <span class="card-source-arrow" aria-hidden="true">↗</span></a>
        ) : (
          <span class={`card-source card-source--${s}`}>{label}</span>
        )
      ))}
    </span>
  </header>

  {p.description && <p class="card-desc">{p.description}</p>}

  {stats.length > 0 && (
    <p class="card-stats">
      {stats.map((s) => (
        <span class="card-stat" title={s.title}>
          {s.icon === 'star' && (
            <svg class="stat-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
            </svg>
          )}
          {s.icon === 'download' && (
            <svg class="stat-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M5 20h14v-2H5v2zM19 9h-4V3H9v6H5l7 7 7-7z" />
            </svg>
          )}
          {s.icon === 'users' && (
            <svg class="stat-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
            </svg>
          )}
          {s.icon === 'calendar' && (
            <svg class="stat-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z" />
            </svg>
          )}
          {s.text}
        </span>
      ))}
    </p>
  )}

  {detailHref && (
    <a class="card-detail-link" href={detailHref}>Details →</a>
  )}
</article>
