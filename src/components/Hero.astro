---
import Stat from './Stat.astro';
import { formatStat, type HeroStats } from '../lib/aggregate-stats';
import { sourceLabel } from '../lib/source-label';
import config from '../lib/load-config';

interface Props {
  stats: HeroStats;
}

const { stats } = Astro.props;
const tagline = config.meta.siteTagline;
const portfolioCount = Math.max(0, stats.totalProjects - stats.openSourceCount);

/** Join a list of source-group keys into a presentable inline string.
 *  Uses sourceLabel for friendly names ('npm', 'Docker', 'GitHub', …) and
 *  an Oxford-style comma + " and " for the last item when there are ≥3. */
function joinSources(keys: string[]): string {
  const labels = keys.map((k) => sourceLabel(k));
  if (labels.length === 0) return '';
  if (labels.length === 1) return labels[0];
  if (labels.length === 2) return `${labels[0]} and ${labels[1]}`;
  return `${labels.slice(0, -1).join(', ')}, and ${labels.at(-1)}`;
}

// Generic sublabel under each tile; the (?) info-tooltip carries the
// platform-specific detail so the line stays short on mobile.
const downloadsInfo = stats.downloadSources.length
  ? `Cumulative install events across ${joinSources(stats.downloadSources)}.`
  : undefined;
const usersInfo = stats.activeUsersSources.length
  ? `Weekly active users reported by ${joinSources(stats.activeUsersSources)}.`
  : undefined;
const starsInfo =
  'Stars on GitHub and Docker Hub combined with positive (≥4★) ratings counted as "likes".';
const projectsCount = stats.totalProjects;
const projectsSublabel = `${stats.openSourceCount} open-source · ${portfolioCount} portfolio`;
const projectsInfo =
  'Open-source — projects with publicly available source code. Portfolio — closed-source or retired projects.';
---
<section class="hero">
  {tagline && (
    <p class="eyebrow">
      <span class="eyebrow-mark" aria-hidden="true">✦</span>
      <span>{tagline}</span>
    </p>
  )}
  <h1 class="hero-title">{config.meta.siteTitle}</h1>
  <div class="section-group">
    <div class="section-divider section-divider--labeled" role="separator">
      <span>Project Statistics</span>
    </div>
    <div class="hero-stats">
    <Stat
      icon="star"
      value={`${formatStat(stats.starsAndLikes)}+`}
      label="Stars & likes"
      sublabel={`across ${stats.totalProjects} ${stats.totalProjects === 1 ? 'project' : 'projects'}`}
      info={starsInfo}
    />
    {config.ui.hero.showDownloads && stats.downloadsAndPulls > 0 && (
      <Stat
        icon="download"
        value={`${formatStat(stats.downloadsAndPulls)}+`}
        label="Downloads & pulls"
        sublabel="lifetime installs and pulls"
        info={downloadsInfo}
      />
    )}
    {config.ui.hero.showUsers && stats.activeUsers > 0 && (
      <Stat
        icon="users"
        value={`${formatStat(stats.activeUsers)}+`}
        label="Active users"
        sublabel="weekly active users"
        info={usersInfo}
      />
    )}
    <Stat
      icon="projects"
      value={String(projectsCount)}
      label="Projects shipped"
      sublabel={projectsSublabel}
      info={projectsInfo}
    />
    </div>
  </div>
</section>
