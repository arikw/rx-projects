---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProfilePresence from '../components/ProfilePresence.astro';
import ReviewCarousel from '../components/ReviewCarousel.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import SiteAbout from '../components/SiteAbout.astro';
import AuthorBio from '../components/AuthorBio.astro';
import config from '../lib/load-config';
import { loadProjects, getProfiles, getSnapshot } from '../lib/load-projects';
import { aggregateStats } from '../lib/aggregate-stats';
import { pickCarouselReviews } from '../lib/pick-reviews';
import { featuredScore } from '../lib/featured-score';

const allProjects = await loadProjects();
const profiles = getProfiles();
const stats = aggregateStats(allProjects);

// Resolve which avatar (if any) to render in the author bio. Honours
// config.user.profileImage; defaults to the first profile fact that has one.
function resolveProfileImage(): string | null {
  const pref = config.user.profileImage;
  if (pref === false) return null;
  if (typeof pref === 'string' && /^https?:\/\//.test(pref)) return pref;
  if (typeof pref === 'string' && pref.length > 0) {
    return profiles.find((p) => p.source === pref)?.avatar ?? null;
  }
  return profiles.find((p) => p.avatar)?.avatar ?? null;
}
const profileImage = resolveProfileImage();
// "Last updated" = the most recent moment any connector actually attempted
// to fetch data, taken from the in-memory snapshot. Stable across refreshes
// of the same build (so the diff-stats logic's lastSeen.generatedAt only
// advances when the data actually does). Falls back to the current time
// when no snapshot is present (very first build, no scrapes yet).
const snapshotForTs = getSnapshot();
const attemptTimes = snapshotForTs
  ? Object.values(snapshotForTs.connectors)
      .map((c) => c?.lastAttempt?.at)
      .filter((s): s is string => !!s)
  : [];
const lastUpdatedIso = attemptTimes.length > 0
  ? attemptTimes.sort().at(-1)!
  : new Date().toISOString();
const lastUpdatedLabel = new Date(lastUpdatedIso).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
});

// Featured projects no longer get their own row — they're pinned to the
// top of the project grid via the default "Featured" sort. Their order
// follows the user's hand-curated `config.featured` array; everything
// non-featured falls through to `featuredScore` within itself (weighted
// mix of liveness + external presence + visual richness + recency +
// log-popularity, defined in src/lib/featured-score.ts).
const featuredOrder = new Map(config.featured.map((slug, i) => [slug, i] as const));
const featuredRank = (p: (typeof allProjects)[number]): number =>
  featuredOrder.get(p.id) ?? Infinity;

// Default sort = featured-then-featuredScore. Mirror the client-side
// default in ProjectGrid so the SSR HTML matches what the user sees
// pre-hydration. Pure score sort: pinned items first, then exact
// score descending, then title for deterministic ties. No bucket or
// group-key tricks — popularity is allowed to clearly dominate when
// there's a meaningful gap.
const sortedAll = [...allProjects].sort((a, b) => {
  const ra = featuredRank(a);
  const rb = featuredRank(b);
  if (ra !== rb) return ra - rb;
  const sa = featuredScore(a);
  const sb = featuredScore(b);
  if (sa !== sb) return sb - sa;
  return a.title.localeCompare(b.title);
});

const carouselReviews = pickCarouselReviews(allProjects, 10);

const dashboardState = {
  version: 1,
  generatedAt: lastUpdatedIso,
  hero: {
    starsAndLikes: stats.starsAndLikes,
    downloadsAndPulls: stats.downloadsAndPulls,
    activeUsers: stats.activeUsers,
    totalProjects: stats.totalProjects,
  },
  projects: Object.fromEntries(
    sortedAll.map((p) => [p.id, {
      stars: p.stats.stars ?? 0,
      downloads: p.stats.downloads ?? 0,
      downloadsMonthly: p.stats.downloadsMonthly ?? 0,
      users: p.stats.users ?? 0,
      installs: p.stats.installs?.value ?? 0,
    }]),
  ),
  profiles: Object.fromEntries(
    profiles.map((p) => [p.source, {
      headline: {
        label: p.headline.label,
        value: typeof p.headline.value === 'number' ? p.headline.value : 0,
      },
      details: (p.details ?? []).map((d) => ({
        label: d.label,
        value: typeof d.value === 'number' ? d.value : 0,
      })),
    }]),
  ),
};
---

<BaseLayout
  title={config.meta.siteTitle}
  description={config.meta.siteDescription}
>
  <Hero stats={stats} />
  {profiles.length > 0 && (
    <div class="section-group">
      <div class="section-divider section-divider--labeled" role="separator">
        <span>Profile Statistics</span>
      </div>
      <ProfilePresence profiles={profiles} />
    </div>
  )}
  {config.meta.siteAbout && (
    <div class="section-group">
      <div class="section-divider section-divider--labeled" role="separator">
        <span>Intro</span>
      </div>
      <SiteAbout markdown={config.meta.siteAbout} />
    </div>
  )}
  <p class="visit-summary" hidden></p>
  <ProjectGrid projects={sortedAll} pageSize={config.ui.pageSize} />
  {carouselReviews.length > 0 && (
    <div class="section-group">
      <div class="section-divider section-divider--labeled" role="separator">
        <span>Reviews</span>
      </div>
      <ReviewCarousel reviews={carouselReviews} />
    </div>
  )}
  {config.user.bio && <AuthorBio name={config.user.name} bio={config.user.bio} avatar={profileImage} />}
  <footer class="site-foot">
    <p class="site-foot-meta">
      Last updated <time datetime={lastUpdatedIso}>{lastUpdatedLabel}</time>
    </p>
    <p class="site-foot-attribution">
      <span class="site-foot-mark" aria-hidden="true">✦</span>
      Built with
      <a
        href="https://github.com/arikw/rx-dev-dashboard"
        target="_blank"
        rel="noopener"
      >rx-dev-dashboard</a>
    </p>
  </footer>
  <script type="application/json" id="dashboard-state" set:html={JSON.stringify(dashboardState)} is:inline />
</BaseLayout>

<script>
  import '../scripts/demo-deltas';
  import '../scripts/diff-stats';
  import '../scripts/delta-tooltip';
  import '../scripts/delta-toggle';
</script>
