---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeaturedRow from '../components/FeaturedRow.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import SiteAbout from '../components/SiteAbout.astro';
import AuthorBio from '../components/AuthorBio.astro';
import config from '../lib/load-config';
import { loadProjects } from '../lib/load-projects';
import { aggregateStats } from '../lib/aggregate-stats';

const allProjects = await loadProjects();
const stats = aggregateStats(allProjects);
// Build timestamp — emitted into the static HTML; the cron-driven rebuild
// in .github/workflows/deploy.yml refreshes it daily.
const lastUpdated = new Date().toISOString();

const featuredOrder = new Map(config.featured.map((slug, i) => [slug, i]));

const featured = allProjects
  .filter((p) => p.featured)
  .sort((a, b) => (featuredOrder.get(a.id) ?? 999) - (featuredOrder.get(b.id) ?? 999));

function signal(p: (typeof allProjects)[number]): number {
  return (
    (p.stats.stars ?? 0) +
    (p.stats.downloads ?? 0) +
    (p.stats.installs?.value ?? 0) +
    (p.stats.users ?? 0)
  );
}

// "All projects" really shows all of them — featured ones get highlighted
// in the row above but also appear here so the source-filter counts and
// the popularity/year sort include the whole catalogue.
const sortedAll = [...allProjects].sort((a, b) => signal(b) - signal(a));
---

<BaseLayout
  title={config.meta.siteTitle}
  description={config.meta.siteDescription}
>
  <Hero stats={stats} lastUpdated={lastUpdated} />
  {config.meta.siteAbout && <SiteAbout markdown={config.meta.siteAbout} />}
  <FeaturedRow projects={featured} />
  <ProjectGrid projects={sortedAll} pageSize={config.ui.pageSize} />
  {config.user.bio && <AuthorBio name={config.user.name} bio={config.user.bio} />}
</BaseLayout>
