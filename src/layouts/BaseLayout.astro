---
import BaseHead from '../components/BaseHead.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import config from '../lib/load-config';
import '@fontsource-variable/fraunces';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  author?: string;
}

const { title, description, ogType, author } = Astro.props;
const home = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} ogType={ogType} author={author} />
  </head>
  <body>
    <script>
      document.addEventListener('click', (e) => {
        if (!(e.target instanceof Element)) return;
        if (e.target.closest('.stat-delta')) {
          e.preventDefault();
          e.stopPropagation();
        }
      }, true);
      const header = document.querySelector('.site-header');
      const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 0);
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    </script>
    <header class="site-header">
      <nav>
        <a href={home} class="brand">
          <span class="brand-dot" aria-hidden="true"></span>
          <span>{config.meta.siteTitle}</span>
        </a>
        <div class="nav-actions">
            <button
              type="button"
              class="delta-toggle"
              data-delta-toggle
              data-tooltip=""
              aria-label="Toggle change indicators"
              hidden
            >
              <svg class="delta-toggle-eye-open" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 5C7 5 2.7 8.1 1 12.5 2.7 17 7 20 12 20s9.3-3 11-7.5C21.3 8.1 17 5 12 5zm0 12.5a5 5 0 1 1 0-10 5 5 0 0 1 0 10zm0-2.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z" />
              </svg>
              <svg class="delta-toggle-eye-shut" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 5C7 5 2.7 8.1 1 12.5c.84 2.2 2.3 4.05 4.16 5.4l-2.3 2.3 1.4 1.4 17-17-1.4-1.4-3.05 3.05A11.4 11.4 0 0 0 12 5zm0 3a4.5 4.5 0 0 1 4.5 4.5c0 .59-.12 1.16-.32 1.68l-5.86-5.86c.53-.2 1.1-.32 1.68-.32zM4.5 12.5A9.4 9.4 0 0 1 12 8c.46 0 .9.04 1.34.12L11.5 9.96A2.5 2.5 0 0 0 9.96 11.5L7.6 13.86A7.4 7.4 0 0 1 4.5 12.5zM12 20a11.4 11.4 0 0 1-3.34-.5l1.66-1.66c.55.1 1.12.16 1.68.16a9.4 9.4 0 0 0 7.5-3.74l-2.2-2.2c.2-.51.32-1.07.32-1.66 0-.56-.06-1.13-.16-1.68l1.66-1.66a11.4 11.4 0 0 1 3.34 3.34C21.3 16.9 17 20 12 20z" />
              </svg>
              <span class="delta-toggle-dot" aria-hidden="true"></span>
            </button>
            <ThemeToggle />
        </div>
      </nav>
    </header>
    <div class="page">
      <main class="site-main">
        <slot />
      </main>
    </div>
  </body>
</html>
